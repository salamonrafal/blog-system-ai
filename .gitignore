# Cache and logs (Symfony2)
/app/cache/*
/app/logs/*
!app/cache/.gitkeep
!app/logs/.gitkeep

# Secrets
/config/secrets/*/*.decrypt.private.php

# Email spool folder
/app/spool/*

# Cache, session files and logs (Symfony3)
/var/cache/*
/var/logs/*
/var/sessions/*
/var/data.db
!var/cache/.gitkeep
!var/logs/.gitkeep
!var/sessions/.gitkeep
/var/dev-server.pid
/var/backup/*

# Logs (Symfony4)
/var/log/*
!var/log/.gitkeep

# Exports
/var/exports/*
!var/exports/.gitkeep

# Imports
/var/imports/*
!var/imports/.gitkeep

# Parameters
/app/config/parameters.yml
/app/config/parameters.ini

# Managed by Composer
/app/bootstrap.php.cache
/var/bootstrap.php.cache
/bin/*
!bin/console
!bin/db-create.php
!bin/dev-router.php
!bin/dev-server.php
!bin/symfony_requirements
/vendor/

# Assets and user uploads
/web/bundles/
/web/uploads/

# PHPUnit
/app/phpunit.xml
/phpunit.xml
/.phpunit.cache/

# Build data
/build/

# Composer PHAR
/composer.phar

# Backup entities generated with doctrine:generate:entities command
**/Entity/*~

# Embedded web-server pid file
/.web-server-pid

# Environment variables file
.env

# AI data
/_ai_data/