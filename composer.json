{
    "name": "blog-system-ai/blog",
    "description": "Symfony blog foundation with article management",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.2",
        "symfony/console": "^7.0",
        "symfony/doctrine-bridge": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/form": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/password-hasher": "^7.0",
        "symfony/property-access": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/security-bundle": "^7.0",
        "symfony/security-csrf": "^7.0",
        "symfony/string": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/var-exporter": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "phpunit --configuration phpunit.xml.dist"
        ],
        "db:create": [
            "@php bin/db-create.php"
        ],
        "db:migration:diff": [
            "@php bin/console doctrine:migrations:diff"
        ],
        "db:migrate": [
            "@php bin/console doctrine:migrations:migrate --no-interaction"
        ],
        "user:create-admin": [
            "@php bin/console app:user:create-admin"
        ],
        "article-export:process-queue": [
            "@php bin/console app:article-export:process-queue"
        ],
        "article-import:process-queue": [
            "@php bin/console app:article-import:process-queue"
        ],
        "serve:debug": [
            "@php bin/dev-server.php restart"
        ],
        "serve:debug:start": [
            "@php bin/dev-server.php start"
        ],
        "serve:debug:stop": [
            "@php bin/dev-server.php stop"
        ],
        "serve:debug:restart": [
            "@php bin/dev-server.php restart"
        ],
        "serve:debug:status": [
            "@php bin/dev-server.php status"
        ],
        "post-install-cmd": [
            "@php bin/console cache:clear"
        ],
        "post-update-cmd": [
            "@php bin/console cache:clear"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    }
}
