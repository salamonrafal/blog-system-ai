{% extends 'base.html.twig' %}

{% block title %}Stan kolejek | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://queue-status</span>
            </div>

            <div class="dashboard-feed-intro">
                <div class="queue-status-intro-header">
                    <div class="queue-status-intro-copy">
                        <h1 data-i18n="admin_queue_status_title">Stan kolejek</h1>
                        <p class="lede" data-i18n="admin_queue_status_lede">Lista pokazuje elementy gotowe do przetworzenia przez zadanie w tle. Widoczne są tylko wpisy oczekujące w kolejkach eksportu i importu.</p>
                    </div>
                    <div class="actions">
                        <a class="button secondary" href="{{ path('admin_queue_status') }}">Odśwież</a>
                        {% if has_pending_queue_items %}
                            <form method="post" action="{{ path('admin_queue_status_clear') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('clear_queue_items') }}">
                                <button
                                    class="button secondary button-danger"
                                    type="button"
                                    data-action="confirm-clear-queue"
                                    data-i18n="admin_queue_clear"
                                >
                                    Wyczyść kolejkę
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>

            {% if pending_export_queue_items is not empty or pending_import_queue_items is not empty %}
                {% if pending_export_queue_items is not empty %}
                    <div class="dashboard-feed-intro">
                        <div class="queue-status-intro-copy">
                            <h2>Eksporty oczekujące</h2>
                        </div>
                    </div>
                    <div class="table-wrap article-index-table-wrap">
                        <table>
                            <thead>
                            <tr>
                                <th data-i18n="admin_queue_table_id">ID</th>
                                <th class="queue-status-title-column" data-i18n="admin_table_title">Tytuł</th>
                                <th data-i18n="admin_queue_table_type">Typ kolejki</th>
                                <th data-i18n="admin_queue_table_user">Użytkownik</th>
                                <th data-i18n="admin_queue_table_created">Dodano</th>
                                <th data-i18n="admin_table_action">Akcja</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for queue_item in pending_export_queue_items %}
                                <tr>
                                    <td>{{ queue_item.id }}</td>
                                    <td class="queue-status-title-cell">
                                        <a href="{{ path('admin_article_edit', {id: queue_item.article.id}) }}">{{ queue_item.article.title }}</a>
                                    </td>
                                    <td data-i18n="admin_queue_type_article_export">Eksport artykułu</td>
                                    <td>
                                        {% if queue_item.requestedBy %}
                                            {{ queue_item.requestedBy.displayName }}
                                        {% else %}
                                            <span data-i18n="admin_table_system">System</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ queue_item.createdAt|user_date }}</td>
                                    <td>
                                        <div class="actions">
                                            <form method="post" action="{{ path('admin_queue_status_export_delete', {id: queue_item.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_queue_item_' ~ queue_item.id) }}">
                                                <button
                                                    class="button secondary button-danger article-action-button"
                                                    type="submit"
                                                    data-i18n-tooltip="admin_queue_delete"
                                                    data-tooltip="Usuń z kolejki"
                                                    aria-label="Usuń z kolejki"
                                                >
                                                    <span class="article-action-icon is-delete" aria-hidden="true"></span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}

                {% if pending_import_queue_items is not empty %}
                    <div class="dashboard-feed-intro">
                        <div class="queue-status-intro-copy">
                            <h2>Importy oczekujące</h2>
                        </div>
                    </div>
                    <div class="table-wrap article-index-table-wrap">
                        <table>
                            <thead>
                            <tr>
                                <th data-i18n="admin_queue_table_id">ID</th>
                                <th class="queue-status-title-column" data-i18n="admin_queue_table_file">Plik</th>
                                <th data-i18n="admin_queue_table_type">Typ kolejki</th>
                                <th data-i18n="admin_queue_table_user">Użytkownik</th>
                                <th data-i18n="admin_queue_table_created">Dodano</th>
                                <th data-i18n="admin_table_action">Akcja</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for queue_item in pending_import_queue_items %}
                                <tr>
                                    <td>{{ queue_item.id }}</td>
                                    <td class="queue-status-title-cell">
                                        <strong>{{ queue_item.originalFilename }}</strong><br>
                                        <span class="meta">{{ queue_item.filePath|split('/')|last }}</span>
                                    </td>
                                    <td data-i18n="admin_queue_type_article_import">Import artykułu</td>
                                    <td>
                                        {% if queue_item.requestedBy %}
                                            {{ queue_item.requestedBy.displayName }}
                                        {% else %}
                                            <span data-i18n="admin_table_system">System</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ queue_item.createdAt|user_date }}</td>
                                    <td>
                                        <div class="actions">
                                            <form method="post" action="{{ path('admin_queue_status_import_delete', {id: queue_item.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_import_queue_item_' ~ queue_item.id) }}">
                                                <button
                                                    class="button secondary button-danger article-action-button"
                                                    type="submit"
                                                    data-tooltip="Usuń z kolejki"
                                                    aria-label="Usuń z kolejki"
                                                >
                                                    <span class="article-action-icon is-delete" aria-hidden="true"></span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            {% elseif has_pending_queue_items %}
                <div class="blog-empty-state">
                    <p class="meta blog-empty-state-message" role="status">W kolejce są ukryte lub osierocone wpisy. Użyj przycisku Wyczyść kolejkę, aby usunąć wszystkie oczekujące elementy.</p>
                </div>
            {% else %}
                <div class="blog-empty-state">
                    <p class="meta blog-empty-state-message" role="status" data-i18n="admin_queue_no_items">Brak elementów oczekujących na przetworzenie.</p>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
