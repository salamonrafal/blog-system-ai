{% extends 'base.html.twig' %}

{% block title %}Eksporty | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://exports</span>
            </div>

            <div class="dashboard-feed-intro">
                <div class="queue-status-intro-header">
                    <div class="queue-status-intro-copy">
                        <h1 data-i18n="admin_exports_title">Eksporty</h1>
                        <p class="lede" data-i18n="admin_exports_lede">Lista pokazuje gotowe paczki eksportu artykułów i kategorii zapisane przez zadanie działające w tle. Każdy wpis zawiera plik gotowy do późniejszego importu.</p>
                    </div>
                    <div class="actions">
                        <a class="button secondary" href="{{ path('admin_article_export_index') }}" data-i18n="admin_refresh">Odśwież</a>
                        {% if exports is not empty %}
                            <form method="post" action="{{ path('admin_article_export_clear') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('clear_article_exports') }}">
                                <button
                                    class="button secondary button-danger"
                                    type="button"
                                    data-action="confirm-clear-exports"
                                    data-i18n="admin_exports_clear"
                                >
                                    Usuń wszystkie eksporty
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="article-index-toolbar">
                <form method="get" class="article-index-filter-panel" data-i18n-aria="admin_exports_filters_aria" aria-label="Filtry listy eksportów">
                    <span class="article-index-filter-label" data-i18n="blog_filters">Filtry</span>
                    <input type="hidden" name="type" value="{{ selected_type ? selected_type.value : '' }}" data-export-type-filter-input>
                    <div class="article-index-filter-dropdown" data-export-type-filter>
                        <button
                            type="button"
                            class="article-index-filter-trigger"
                            data-action="toggle-export-type-filter"
                            data-i18n-aria="{{ selected_type ? selected_type.translationKey : 'admin_exports_filter_all_types' }}"
                            aria-haspopup="true"
                            aria-expanded="false"
                            aria-controls="article-export-type-filter-panel"
                            aria-label="{{ selected_type ? selected_type.label : 'Wszystkie typy' }}"
                        >
                            <span class="article-index-filter-trigger-label" data-i18n="{{ selected_type ? selected_type.translationKey : 'admin_exports_filter_all_types' }}">{{ selected_type ? selected_type.label : 'Wszystkie typy' }}</span>
                            <span class="article-index-filter-trigger-caret" aria-hidden="true">
                                <svg viewBox="0 0 24 24">
                                    <path d="m7 10 5 5 5-5"></path>
                                </svg>
                            </span>
                        </button>
                        <div class="article-index-filter-options" id="article-export-type-filter-panel" data-i18n-aria="admin_exports_filter_type" aria-label="Typ eksportu" aria-hidden="true" hidden>
                            <button type="button" class="article-index-filter-option{{ not selected_type ? ' is-selected' : '' }}" data-export-type-option data-value="" data-i18n="admin_exports_filter_all_types">
                                Wszystkie typy
                            </button>
                            {% for export_type in export_types %}
                                <button
                                    type="button"
                                    class="article-index-filter-option{{ selected_type and selected_type.value == export_type.value ? ' is-selected' : '' }}"
                                    data-export-type-option
                                    data-value="{{ export_type.value }}"
                                    data-i18n="{{ export_type.translationKey }}"
                                >
                                    {{ export_type.label }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                    {% if selected_type %}
                        <a class="button secondary article-index-filter-reset" href="{{ path('admin_article_export_index') }}" data-i18n="admin_exports_filter_clear">Wyczyść</a>
                    {% endif %}
                </form>
            </div>

            {% if exports is not empty %}
                <div class="table-wrap article-index-table-wrap">
                    <table>
                        <thead>
                        <tr>
                            <th data-i18n="admin_exports_table_id">ID</th>
                            <th data-i18n="admin_exports_table_type">Typ</th>
                            <th data-i18n="admin_exports_table_status">Status</th>
                            <th data-i18n="admin_exports_table_user_created">Użytkownik / utworzono</th>
                            <th class="article-export-file-column" data-i18n="admin_exports_table_file">Plik</th>
                            <th data-i18n="admin_table_action">Akcja</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for export in exports %}
                            <tr>
                                <td>{{ export.id }}</td>
                                <td>
                                    <span data-i18n="{{ export.type.translationKey }}">{{ export.type.label }}</span>
                                </td>
                                <td>
                                    {% if export.status.value == 'downloaded' %}
                                        <span data-i18n="admin_exports_status_downloaded">Pobrany</span>
                                    {% else %}
                                        <span data-i18n="admin_exports_status_new">Nowy</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if export.requestedBy %}
                                        {{ export.requestedBy.displayName }}
                                    {% else %}
                                        <span data-i18n="admin_table_system">System</span>
                                    {% endif %}<br>
                                    <span class="meta">{{ export.createdAt|user_date }}</span>
                                </td>
                                <td class="article-export-file-cell">{{ export.filePath|split('/')|last }}</td>
                                <td>
                                    <div class="actions">
                                        <a
                                            class="button secondary article-action-button"
                                            href="{{ path('admin_article_export_download', {id: export.id}) }}"
                                            data-i18n-tooltip="admin_exports_download"
                                            data-tooltip="Pobierz plik eksportu"
                                            data-i18n-aria="admin_exports_download"
                                            aria-label="Pobierz plik eksportu"
                                        >
                                            <span class="article-action-icon is-export" aria-hidden="true"></span>
                                        </a>
                                        <form method="post" action="{{ path('admin_article_export_delete', {id: export.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_article_export_' ~ export.id) }}">
                                            <button
                                                class="button secondary button-danger article-action-button"
                                                type="button"
                                                data-action="confirm-delete-export"
                                                data-export-file="{{ export.filePath }}"
                                                data-i18n-tooltip="admin_table_delete"
                                                data-tooltip="Usuń"
                                                data-i18n-aria="admin_table_delete"
                                                aria-label="Usuń"
                                            >
                                                <span class="article-action-icon is-delete" aria-hidden="true"></span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if total_pages > 1 %}
                    <nav class="blog-pagination article-index-pagination" aria-label="Paginacja eksportów w panelu administracyjnym">
                        {% if current_page > 1 %}
                            <a class="btn blog-pagination-link blog-pagination-link-icon" href="{{ path('admin_article_export_index', pagination_route_params|merge({ page: current_page - 1 })) }}" aria-label="Poprzednia strona">
                                <span aria-hidden="true">&lsaquo;</span>
                            </a>
                        {% else %}
                            <span class="btn blog-pagination-link blog-pagination-link-icon is-disabled" aria-disabled="true" aria-label="Poprzednia strona">
                                <span aria-hidden="true">&lsaquo;</span>
                            </span>
                        {% endif %}

                        <div class="blog-pagination-pages">
                            {% for item in pagination_items %}
                                {% if item == '...' %}
                                    <span class="blog-pagination-ellipsis" aria-hidden="true">...</span>
                                {% elseif item == current_page %}
                                    <span class="btn blog-pagination-link is-current" aria-current="page">{{ item }}</span>
                                {% else %}
                                    <a class="btn blog-pagination-link" href="{{ path('admin_article_export_index', pagination_route_params|merge({ page: item })) }}">{{ item }}</a>
                                {% endif %}
                            {% endfor %}
                        </div>

                        {% if current_page < total_pages %}
                            <a class="btn blog-pagination-link blog-pagination-link-icon" href="{{ path('admin_article_export_index', pagination_route_params|merge({ page: current_page + 1 })) }}" aria-label="Następna strona">
                                <span aria-hidden="true">&rsaquo;</span>
                            </a>
                        {% else %}
                            <span class="btn blog-pagination-link blog-pagination-link-icon is-disabled" aria-disabled="true" aria-label="Następna strona">
                                <span aria-hidden="true">&rsaquo;</span>
                            </span>
                        {% endif %}
                    </nav>
                {% endif %}
            {% else %}
                <div class="blog-empty-state">
                    <p class="meta blog-empty-state-message" role="status" data-i18n="admin_exports_no_items">Brak gotowych eksportów.</p>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
