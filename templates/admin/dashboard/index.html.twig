{% extends 'base.html.twig' %}

{% block title %}Admin | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">blog://published-feed</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1 data-i18n="admin_dashboard_title">Centrum operacji treści</h1>
                <p class="lede" data-i18n="admin_dashboard_lede">Panel administracyjny dopasowany do układu aplikacji, gotowy na workflow redakcyjny, moderację i publikację.</p>

                <div class="actions">
                    <a class="button" href="{{ path('admin_article_new') }}" data-i18n="blog_create_article">Utwórz artykuł</a>
                    <a class="button secondary" href="{{ path('admin_article_index') }}" data-i18n="admin_browse_articles">Przeglądaj artykuły</a>
                </div>
            </div>

            {% if published_articles is not empty %}
                <div class="quick-links feed-panel-list">
                    {% for article in published_articles %}
                        <article class="big-link no-hover article-subpanel">
                            <div class="article-subpanel-header">
                                <h2 class="article-subpanel-title">{{ article.title }}</h2>
                                <div class="meta article-subpanel-meta">
                                    {{ article.publishedAt ? article.publishedAt|date('Y-m-d H:i') : article.createdAt|date('Y-m-d H:i') }}
                                    |
                                    <span data-lang="pl">{{ article.language.value == 'pl' ? 'Polski (PL)' : 'Angielski (EN)' }}</span>
                                    <span data-lang="en">{{ article.language.value == 'pl' ? 'Polski (PL)' : 'English (EN)' }}</span>
                                    |
                                    <span data-lang="pl">
                                        {% if article.status.value == 'draft' %}Szkic{% elseif article.status.value == 'review' %}W recenzji{% else %}Opublikowany{% endif %}
                                    </span>
                                    <span data-lang="en">
                                        {% if article.status.value == 'draft' %}Draft{% elseif article.status.value == 'review' %}In review{% else %}Published{% endif %}
                                    </span>
                                </div>
                            </div>
                            <div class="big-link-copy">
                                <span>{{ article.excerpt ?: article.content|slice(0, 180) ~ (article.content|length > 180 ? '...' : '') }}</span>
                            </div>
                            <div class="article-subpanel-actions">
                                <a class="btn article-subpanel-button" href="{{ path('admin_article_edit', {id: article.id}) }}" data-i18n="admin_edit_article">Edytuj artykuł</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <p class="meta" data-i18n="blog_no_articles">Brak opublikowanych artykułów.</p>
            {% endif %}
        </div>
    </section>

    <section class="section">
        <div class="card">
            <div class="card-header">
                <span class="pill" data-i18n="admin_quick_actions">Szybkie akcje</span>
            </div>
            <div class="quick-links">
                <a class="big-link" href="{{ path('admin_article_new') }}">
                    <strong data-i18n="admin_quick_new_article">Nowy artykuł</strong>
                    <span class="supporting-copy" data-i18n="admin_quick_new_article_desc">Rozpocznij nowy szkic z automatycznie generowanym slugiem.</span>
                </a>
                <a class="big-link" href="{{ path('admin_article_index') }}">
                    <strong data-i18n="admin_quick_manage_articles">Zarządzaj artykułami</strong>
                    <span class="supporting-copy" data-i18n="admin_quick_manage_articles_desc">Przeglądaj szkice, wpisy opublikowane i aktualizuj treści.</span>
                </a>
                <a class="big-link" href="{{ path('blog_index') }}">
                    <strong data-i18n="admin_quick_open_blog">Otwórz publiczny blog</strong>
                    <span class="supporting-copy" data-i18n="admin_quick_open_blog_desc">Wróć do widoku, który widzą już czytelnicy.</span>
                </a>
            </div>
        </div>
    </section>
{% endblock %}
