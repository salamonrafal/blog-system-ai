{% extends 'base.html.twig' %}

{% block title %}Nowe słowo kluczowe | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://article-keywords/new</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1 data-i18n="admin_article_keyword_new_title">Nowe słowo kluczowe</h1>
                <p class="lede" data-i18n="admin_article_keyword_new_lede">Dodaj słowo kluczowe, wybierz język, ustaw kolor i zdecyduj, czy ma być aktywne w panelu redakcyjnym.</p>
            </div>

            {% include 'admin/article_keyword/_form.html.twig' with { form: form } %}
        </div>
    </section>
{% endblock %}
