{% extends 'base.html.twig' %}

{% block title %}Media | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://media</span>
            </div>

            <div class="dashboard-feed-intro">
                <div class="queue-status-intro-header">
                    <div class="queue-status-intro-copy">
                        <h1 data-i18n="admin_media_upload_title">Dodaj obrazek</h1>
                        <p class="lede" data-i18n="admin_media_upload_lede">Prześlij nowy obrazek do biblioteki mediów. Po zapisaniu od razu zobaczysz go w galerii.</p>
                    </div>
                    <div class="actions">
                        <a class="button secondary" href="{{ path('admin_media_index') }}" data-i18n="admin_refresh">Odśwież</a>
                        <a class="button secondary" href="{{ path('admin_media_gallery') }}" data-i18n="admin_media_open_gallery">Otwórz galerię</a>
                    </div>
                </div>
            </div>

            {{ form_start(form, { attr: { class: 'article-editor-form' } }) }}
                {% if form.vars.errors|length > 0 %}
                    <div class="form-errors article-editor-errors" role="alert">
                        {% for error in form.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="article-editor-fields">
                    {% set image_file_has_errors = form.imageFile.vars.errors|length > 0 %}
                    {% set image_file_error_id = form.imageFile.vars.id ~ '-error' %}
                    {% set image_file_hint_id = form.imageFile.vars.id ~ '-hint' %}
                    {% set image_file_described_by = image_file_hint_id ~ (image_file_has_errors ? ' ' ~ image_file_error_id : '') %}
                    <div class="field article-editor-field{{ image_file_has_errors ? ' has-error' : '' }}">
                        {{ form_label(form.imageFile, null, { label_attr: { class: 'sr-only' } }) }}
                        <div class="file-upload" data-file-upload>
                            {{ form_widget(form.imageFile, { attr: {
                                class: 'sr-only file-upload-input',
                                'aria-describedby': image_file_described_by,
                                'data-file-upload-input': ''
                            }|merge(image_file_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                            <div class="file-upload-surface" data-file-upload-surface>
                                <div class="file-upload-topbar">
                                    <span class="file-upload-icon" aria-hidden="true"></span>
                                    <span
                                        class="file-upload-filename"
                                        data-file-upload-filename
                                        data-empty-label-key="file_upload_no_file"
                                        data-selected-label-key="file_upload_selected"
                                        data-i18n="file_upload_no_file"
                                    >Nie wybrano pliku</span>
                                    <button
                                        type="button"
                                        class="button secondary file-upload-trigger"
                                        data-file-upload-trigger
                                        data-i18n="file_upload_choose"
                                    >Wybierz plik</button>
                                    <button
                                        type="button"
                                        class="article-keyword-help-trigger"
                                        data-i18n-tooltip="admin_media_form_file_hint"
                                        data-i18n-aria="admin_media_form_file_help_aria"
                                        data-tooltip="Dozwolone formaty: JPG, PNG, WEBP, GIF, AVIF. Maksymalny rozmiar pliku: 5 MB."
                                        data-tooltip-wide="true"
                                        data-tooltip-wrap="true"
                                        aria-label="Pomoc do pola obrazka"
                                    >?</button>
                                </div>
                            </div>
                        </div>
                        <span id="{{ image_file_hint_id }}" class="sr-only" data-i18n="admin_media_form_file_hint">Dozwolone formaty: JPG, PNG, WEBP, GIF, AVIF. Maksymalny rozmiar pliku: 5 MB.</span>
                        {% if image_file_has_errors %}
                            <div id="{{ image_file_error_id }}" class="article-editor-error-message" role="alert">
                                {% for error in form.imageFile.vars.errors %}
                                    <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="actions article-editor-actions">
                    <button type="submit" class="button" data-i18n="admin_media_form_submit">Dodaj obrazek</button>
                    <a class="button secondary" href="{{ path('admin_media_gallery') }}" data-i18n="admin_media_open_gallery">Otwórz galerię</a>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
