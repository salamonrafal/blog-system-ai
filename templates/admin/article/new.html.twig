{% extends 'base.html.twig' %}

{% block title %}New Article | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://article-new</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1>Create article</h1>
                <p class="lede">New entries start as drafts by default and receive a unique slug automatically before saving.</p>
            </div>

            {% include 'admin/article/_form.html.twig' with {
                form: form,
                submit_label: 'Create article'
            } %}
        </div>
    </section>
{% endblock %}
