{% extends 'base.html.twig' %}

{% block title %}Edit {{ article.title }} | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://article-edit</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1 data-i18n="admin_edit_article_title">Edytuj artykuł</h1>
                <p class="lede" data-i18n="admin_edit_article_lede">Aktualizuj treść, metadane i stan publikacji, zachowując istniejący slug.</p>

                <div class="stats">
                    <div class="stat">
                        <strong>{{ article.slug }}</strong>
                        <span class="supporting-copy" data-i18n="admin_permanent_slug">Stały slug</span>
                    </div>
                    <div class="stat">
                        <strong>
                            <span data-lang="pl">
                                {% if article.status.value == 'draft' %}Szkic{% elseif article.status.value == 'review' %}W recenzji{% elseif article.status.value == 'archived' %}Zarchiwizowany{% else %}Opublikowany{% endif %}
                            </span>
                            <span data-lang="en">
                                {% if article.status.value == 'draft' %}Draft{% elseif article.status.value == 'review' %}In review{% elseif article.status.value == 'archived' %}Archived{% else %}Published{% endif %}
                            </span>
                        </strong>
                        <span class="supporting-copy" data-i18n="admin_current_workflow_status">Bieżący status workflow</span>
                    </div>
                    <div class="stat">
                        <strong>{{ article.updatedAt|date('Y-m-d H:i') }}</strong>
                        <span class="supporting-copy" data-i18n="admin_last_update">Data ostatniej aktualizacji</span>
                    </div>
                </div>
            </div>

            {% include 'admin/article/_form.html.twig' with {
                form: form,
                submit_key: 'form_submit_update'
            } %}
        </div>
    </section>
{% endblock %}
