{% extends 'base.html.twig' %}

{% block title %}Edit {{ article.title }} | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="grid-2">
            <div class="panel">
                <p class="eyebrow meta-pill">Admin area</p>
                <h1>Edit article</h1>
                <p class="lede">Update content, metadata and publication state while keeping the existing slug.</p>

                {% include 'admin/article/_form.html.twig' with {
                    form: form,
                    submit_label: 'Update article'
                } %}
            </div>

            <aside class="card">
                <div class="card-header">
                    <span class="pill">Article info</span>
                </div>
                <div class="stats">
                    <div class="stat">
                        <strong>{{ article.slug }}</strong>
                        <span class="supporting-copy">Permanent slug</span>
                    </div>
                    <div class="stat">
                        <strong>{{ article.status.label() }}</strong>
                        <span class="supporting-copy">Current workflow status</span>
                    </div>
                    <div class="stat">
                        <strong>{{ article.updatedAt|date('Y-m-d H:i') }}</strong>
                        <span class="supporting-copy">Last update timestamp</span>
                    </div>
                </div>
            </aside>
        </div>
    </section>
{% endblock %}
