{% extends 'base.html.twig' %}

{% block title %}Manage Articles | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://article-index</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1>Article management</h1>
                <p class="lede">All articles in one place, regardless of status. The table below keeps the admin view compact, while matching the new layout.</p>

                <div class="actions">
                    <a class="button" href="{{ path('admin_article_new') }}">New article</a>
                </div>
            </div>

            <div class="table-wrap article-index-table-wrap">
                <table>
                    <thead>
                    <tr>
                        <th>Title</th>
                        <th>Language</th>
                        <th>Status</th>
                        <th>Slug</th>
                        <th>Updated</th>
                        <th>Action</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for article in articles %}
                        <tr>
                            <td>{{ article.title }}</td>
                            <td>{{ article.language.label() }}</td>
                            <td>{{ article.status.label() }}</td>
                            <td><code>{{ article.slug }}</code></td>
                            <td>{{ article.updatedAt|date('Y-m-d H:i') }}</td>
                            <td><a class="button secondary" href="{{ path('admin_article_edit', {id: article.id}) }}">Edit</a></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6">No articles found.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
