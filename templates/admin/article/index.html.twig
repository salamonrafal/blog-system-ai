{% extends 'base.html.twig' %}

{% block title %}Manage Articles | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://article-index</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1 data-i18n="admin_article_index_title">Zarządzanie artykułami</h1>
                <p class="lede" data-i18n="admin_article_index_lede">Wszystkie artykuły w jednym miejscu, niezależnie od statusu. Tabela poniżej utrzymuje widok administracyjny w zwartej formie.</p>

                <div class="actions">
                    <a class="button" href="{{ path('admin_article_new') }}" data-i18n="admin_quick_new_article">Nowy artykuł</a>
                    {% if articles is not empty %}
                        <form id="article-bulk-export-form" method="post" action="{{ path('admin_article_export_selected') }}" class="article-index-bulk-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('export_articles_bulk') }}">
                            <button
                                class="button secondary"
                                type="submit"
                                data-article-bulk-submit
                                data-i18n="admin_article_bulk_export"
                            >
                                Eksportuj zaznaczone
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>

            <div class="article-index-toolbar">
                <form method="get" class="article-index-filter-panel" aria-label="Filtry listy artykułów">
                    <span class="article-index-filter-label">Filtry</span>
                    <input type="hidden" name="category" value="{{ selected_category ? selected_category.id : '' }}" data-article-category-filter-input>
                    <div class="article-index-filter-dropdown" data-article-category-filter>
                        <button
                            type="button"
                            class="article-index-filter-trigger"
                            data-action="toggle-article-category-filter"
                            aria-haspopup="true"
                            aria-expanded="false"
                            aria-controls="article-index-category-filter-panel"
                        >
                            <span class="article-index-filter-trigger-label">{{ selected_category ? selected_category.name : 'Wszystkie kategorie' }}</span>
                            <span class="article-index-filter-trigger-caret" aria-hidden="true">
                                <svg viewBox="0 0 24 24">
                                    <path d="m7 10 5 5 5-5"></path>
                                </svg>
                            </span>
                        </button>
                        <div class="article-index-filter-options" id="article-index-category-filter-panel" aria-label="Kategorie artykułów">
                            <button type="button" class="article-index-filter-option{{ not selected_category ? ' is-selected' : '' }}" data-article-category-option data-value="">
                                Wszystkie kategorie
                            </button>
                            {% for category in article_categories %}
                                <button
                                    type="button"
                                    class="article-index-filter-option{{ selected_category and selected_category.id == category.id ? ' is-selected' : '' }}"
                                    data-article-category-option
                                    data-value="{{ category.id }}"
                                >
                                    {{ category.name }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                    {% if selected_category %}
                        <a class="button secondary article-index-filter-reset" href="{{ path('admin_article_index') }}">Wyczyść</a>
                    {% endif %}
                </form>
            </div>

            <div class="table-wrap article-index-table-wrap">
                <table>
                    <thead>
                    <tr>
                        <th class="article-index-select-column">
                            {% if articles is not empty %}
                                <input
                                    type="checkbox"
                                    data-article-select-all
                                    data-i18n-aria="admin_article_select_all"
                                    aria-label="Zaznacz wszystkie artykuły"
                                >
                            {% endif %}
                        </th>
                        <th class="article-index-title-column" data-i18n="admin_table_title">Tytuł</th>
                        <th data-i18n="admin_table_author">Autor</th>
                        <th data-i18n="admin_table_status">Status</th>
                        <th data-i18n="admin_table_updated">Aktualizacja</th>
                        <th data-i18n="admin_table_action">Akcja</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for article in articles %}
                        <tr>
                            <td class="article-index-select-cell">
                                <input
                                    type="checkbox"
                                    name="article_ids[]"
                                    value="{{ article.id }}"
                                    form="article-bulk-export-form"
                                    data-article-select-item
                                    data-i18n-aria="admin_article_select"
                                    aria-label="Zaznacz artykuł"
                                >
                            </td>
                            <td class="article-index-title-cell"><a href="{{ path('blog_show', {slug: article.slug}) }}">{{ article.title }}</a></td>
                            <td>
                                {% if article.createdBy %}
                                    {{ article.createdBy.displayName }}
                                {% else %}
                                    <form method="post" action="{{ path('admin_article_assign_to_me', {id: article.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('assign_article_to_me_' ~ article.id) }}">
                                        <button class="button secondary" type="submit">
                                            <span data-lang="pl">Przypisz do mnie</span>
                                            <span data-lang="en">Assign to me</span>
                                        </button>
                                    </form>
                                {% endif %}
                            </td>
                            <td class="article-index-status-cell">
                                <span data-lang="pl">
                                    {% if article.status.value == 'draft' %}Szkic{% elseif article.status.value == 'review' %}W recenzji{% elseif article.status.value == 'archived' %}Zarchiwizowany{% else %}Opublikowany{% endif %}
                                </span>
                                <span data-lang="en">
                                    {% if article.status.value == 'draft' %}Draft{% elseif article.status.value == 'review' %}In review{% elseif article.status.value == 'archived' %}Archived{% else %}Published{% endif %}
                                </span>
                            </td>
                            <td class="article-index-updated-cell">{{ article.updatedAt|user_date }}</td>
                            <td>
                                <div class="actions">
                                    <a
                                        class="button secondary article-action-button"
                                        href="{{ path('admin_article_edit', {id: article.id}) }}"
                                        data-i18n-tooltip="admin_table_edit"
                                        data-tooltip="Edytuj"
                                        aria-label="Edytuj"
                                    >
                                        <span class="article-action-icon is-edit" aria-hidden="true"></span>
                                    </a>
                                    <form method="post" action="{{ path('admin_article_export', {id: article.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('export_article_' ~ article.id) }}">
                                        <button
                                            class="button secondary article-action-button"
                                            type="submit"
                                            data-i18n-tooltip="admin_table_export"
                                            data-tooltip="Eksport"
                                            aria-label="Eksport"
                                        >
                                            <span class="article-action-icon is-export" aria-hidden="true"></span>
                                        </button>
                                    </form>
                                    {% if article.status.value != 'published' %}
                                        <form method="post" action="{{ path('admin_article_publish', {id: article.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('publish_article_' ~ article.id) }}">
                                            <button
                                                class="button secondary article-action-button"
                                                type="submit"
                                                data-i18n-tooltip="admin_table_publish"
                                                data-tooltip="Opublikuj"
                                                aria-label="Opublikuj"
                                            >
                                                <span class="article-action-icon is-publish" aria-hidden="true"></span>
                                            </button>
                                        </form>
                                    {% endif %}
                                    {% if article.status.value == 'archived' %}
                                        <form method="post" action="{{ path('admin_article_delete', {id: article.id}) }}" data-delete-form>
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_article_' ~ article.id) }}">
                                            <button
                                                class="button secondary button-danger article-action-button"
                                                type="button"
                                                data-action="confirm-delete-article"
                                                data-article-title="{{ article.title }}"
                                                data-i18n-tooltip="admin_table_delete"
                                                data-tooltip="Usuń"
                                                aria-label="Usuń"
                                            >
                                                <span class="article-action-icon is-delete" aria-hidden="true"></span>
                                            </button>
                                        </form>
                                    {% else %}
                                        <form method="post" action="{{ path('admin_article_archive', {id: article.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('archive_article_' ~ article.id) }}">
                                            <button
                                                class="button secondary article-action-button"
                                                type="submit"
                                                data-i18n-tooltip="admin_table_archive"
                                                data-tooltip="Archiwizuj"
                                                aria-label="Archiwizuj"
                                            >
                                                <span class="article-action-icon is-archive" aria-hidden="true"></span>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" data-i18n="admin_table_no_articles">Nie znaleziono artykułów.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if total_pages > 1 %}
                <nav class="blog-pagination article-index-pagination" aria-label="Paginacja artykułów w panelu administracyjnym">
                    {% if current_page > 1 %}
                        <a class="btn blog-pagination-link blog-pagination-link-icon" href="{{ path('admin_article_index', pagination_route_params|merge({ page: current_page - 1 })) }}" aria-label="Poprzednia strona">
                            <span aria-hidden="true">&lsaquo;</span>
                        </a>
                    {% else %}
                        <span class="btn blog-pagination-link blog-pagination-link-icon is-disabled" aria-disabled="true" aria-label="Poprzednia strona">
                            <span aria-hidden="true">&lsaquo;</span>
                        </span>
                    {% endif %}

                    <div class="blog-pagination-pages">
                        {% for item in pagination_items %}
                            {% if item == '...' %}
                                <span class="blog-pagination-ellipsis" aria-hidden="true">...</span>
                            {% elseif item == current_page %}
                                <span class="btn blog-pagination-link is-current" aria-current="page">{{ item }}</span>
                            {% else %}
                                <a class="btn blog-pagination-link" href="{{ path('admin_article_index', pagination_route_params|merge({ page: item })) }}">{{ item }}</a>
                            {% endif %}
                        {% endfor %}
                    </div>

                    {% if current_page < total_pages %}
                        <a class="btn blog-pagination-link blog-pagination-link-icon" href="{{ path('admin_article_index', pagination_route_params|merge({ page: current_page + 1 })) }}" aria-label="Następna strona">
                            <span aria-hidden="true">&rsaquo;</span>
                        </a>
                    {% else %}
                        <span class="btn blog-pagination-link blog-pagination-link-icon is-disabled" aria-disabled="true" aria-label="Następna strona">
                            <span aria-hidden="true">&rsaquo;</span>
                        </span>
                    {% endif %}
                </nav>
            {% endif %}
        </div>
    </section>
{% endblock %}
