{% extends 'base.html.twig' %}

{% block title %}Dodaj użytkownika | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">admin://user-new</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1 data-i18n="admin_user_new_title">Dodaj użytkownika</h1>
                <p class="lede" data-i18n="admin_user_new_lede">Utwórz nowe konto redakcyjne lub administracyjne i od razu ustaw podstawowe dane profilu.</p>
            </div>

            {% include 'admin/user/_form.html.twig' with {
                form: form,
                submit_label_key: 'user_form_submit_create',
                submit_label: 'Dodaj użytkownika'
            } %}
        </div>
    </section>
{% endblock %}
