{{ form_start(form, { attr: { class: 'article-editor-form' } }) }}
    {% if form.vars.errors|length > 0 %}
        <div class="form-errors article-editor-errors" role="alert">
            {% for error in form.vars.errors %}
                <p>{{ error.message }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <div class="article-editor-fields">
        {% set email_has_errors = form.email.vars.errors|length > 0 %}
        <div class="field article-editor-field{{ email_has_errors ? ' has-error' : '' }}">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {
                attr: form.email.vars.attr|merge(email_has_errors ? {'aria-invalid': 'true', 'aria-describedby': form.email.vars.id ~ '-error'} : {})
            }) }}
            {% if email_has_errors %}
                <div id="{{ form.email.vars.id }}-error" class="article-editor-error-message" role="alert">
                    {% for error in form.email.vars.errors %}
                        <p>{{ error.message }}</p>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="article-editor-grid">
            {% set full_name_has_errors = form.fullName.vars.errors|length > 0 %}
            <div class="field article-editor-field{{ full_name_has_errors ? ' has-error' : '' }}">
                {{ form_label(form.fullName) }}
                {{ form_widget(form.fullName, {
                    attr: form.fullName.vars.attr|merge(full_name_has_errors ? {'aria-invalid': 'true', 'aria-describedby': form.fullName.vars.id ~ '-error'} : {})
                }) }}
                {% if full_name_has_errors %}
                    <div id="{{ form.fullName.vars.id }}-error" class="article-editor-error-message" role="alert">
                        {% for error in form.fullName.vars.errors %}
                            <p>{{ error.message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {% set nickname_has_errors = form.nickname.vars.errors|length > 0 %}
            <div class="field article-editor-field{{ nickname_has_errors ? ' has-error' : '' }}">
                {{ form_label(form.nickname) }}
                {{ form_widget(form.nickname, {
                    attr: form.nickname.vars.attr|merge(nickname_has_errors ? {'aria-invalid': 'true', 'aria-describedby': form.nickname.vars.id ~ '-error'} : {})
                }) }}
                {% if nickname_has_errors %}
                    <div id="{{ form.nickname.vars.id }}-error" class="article-editor-error-message" role="alert">
                        {% for error in form.nickname.vars.errors %}
                            <p>{{ error.message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        {% set short_bio_has_errors = form.shortBio.vars.errors|length > 0 %}
        <div class="field article-editor-field{{ short_bio_has_errors ? ' has-error' : '' }}">
            {{ form_label(form.shortBio) }}
            {{ form_widget(form.shortBio, {
                attr: form.shortBio.vars.attr|merge(short_bio_has_errors ? {'aria-invalid': 'true', 'aria-describedby': form.shortBio.vars.id ~ '-error'} : {})
            }) }}
            {% if short_bio_has_errors %}
                <div id="{{ form.shortBio.vars.id }}-error" class="article-editor-error-message" role="alert">
                    {% for error in form.shortBio.vars.errors %}
                        <p>{{ error.message }}</p>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {% set avatar_has_errors = form.avatarFile.vars.errors|length > 0 %}
        {% set avatar_error_id = form.avatarFile.vars.id ~ '-error' %}
        {% set avatar_preview_id = form.avatarFile.vars.id ~ '-preview' %}
        {% set avatar_preview_image_id = form.avatarFile.vars.id ~ '-preview-image' %}
        {% set avatar_preview_empty_id = form.avatarFile.vars.id ~ '-preview-empty' %}
        {% set current_avatar = form.vars.data.avatar %}
        {% set avatar_described_by = avatar_has_errors ? avatar_error_id : null %}
        <div class="field article-editor-field{{ avatar_has_errors ? ' has-error' : '' }}" data-avatar-upload>
            {{ form_label(form.avatarFile, null, { label_attr: { class: 'sr-only' } }) }}
            <div class="file-upload" data-file-upload data-file-upload-drop-enabled="false">
                {{ form_widget(form.avatarFile, { attr: form.avatarFile.vars.attr|merge({
                    class: 'sr-only file-upload-input',
                    'data-file-upload-input': '',
                    'data-avatar-input': '',
                    'data-avatar-preview-target': '#' ~ avatar_preview_id
                }|merge(avatar_described_by ? {'aria-describedby': avatar_described_by} : {})|merge(avatar_has_errors ? {'aria-invalid': 'true'} : {})) }) }}
                <div class="file-upload-surface" data-file-upload-surface>
                    <div class="file-upload-topbar">
                        <div
                            id="{{ avatar_preview_id }}"
                            class="user-avatar-upload-preview{{ current_avatar ? ' has-image' : '' }}"
                            data-avatar-preview
                            data-avatar-preview-default-src="{{ current_avatar }}"
                            data-i18n-aria="user_form_avatar_preview_label"
                            aria-label="{{ i18n_fallback('user_form_avatar_preview_label') }}"
                        >
                            <div class="user-avatar-upload-preview-frame">
                                <img
                                    id="{{ avatar_preview_image_id }}"
                                    alt="{{ i18n_fallback('user_form_avatar_preview_alt') }}"
                                    class="user-avatar-upload-preview-image"
                                    data-avatar-preview-image
                                    {% if current_avatar %}src="{{ current_avatar }}"{% endif %}
                                    {{ current_avatar ? '' : 'hidden' }}
                                >
                                <div
                                    id="{{ avatar_preview_empty_id }}"
                                    class="user-avatar-upload-preview-empty"
                                    data-avatar-preview-empty
                                    {{ current_avatar ? 'hidden' : '' }}
                                >
                                    <span class="user-avatar-upload-preview-empty-icon" aria-hidden="true"></span>
                                    <span class="sr-only" data-i18n="user_form_avatar_preview_empty">{{ i18n_fallback('user_form_avatar_preview_empty') }}</span>
                                </div>
                            </div>
                        </div>
                        <span
                            class="file-upload-filename"
                            data-file-upload-filename
                            data-empty-label-key="file_upload_no_file"
                            data-selected-label-key="file_upload_selected"
                            data-i18n="file_upload_no_file"
                        >{{ i18n_fallback('file_upload_no_file') }}</span>
                        <button
                            type="button"
                            class="button secondary file-upload-trigger"
                            data-file-upload-trigger
                            data-i18n="file_upload_choose"
                        >{{ i18n_fallback('file_upload_choose') }}</button>
                        <button
                            type="button"
                            class="article-keyword-help-trigger"
                            data-i18n-tooltip="user_form_avatar_hint"
                            data-i18n-aria="user_form_avatar_help_aria"
                            data-tooltip="{{ i18n_fallback('user_form_avatar_hint') }}"
                            data-tooltip-wide="true"
                            data-tooltip-wrap="true"
                            aria-label="{{ i18n_fallback('user_form_avatar_help_aria') }}"
                        >?</button>
                    </div>
                </div>
            </div>
            {% if avatar_has_errors %}
                <div id="{{ avatar_error_id }}" class="article-editor-error-message" role="alert">
                    {% for error in form.avatarFile.vars.errors %}
                        {% include 'admin/_validation_error.html.twig' with { error: error } %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="article-editor-grid">
            {% set is_admin_has_errors = form.isAdmin.vars.errors|length > 0 %}
            <div class="field article-editor-field{{ is_admin_has_errors ? ' has-error' : '' }}">
                <div class="article-editor-switch-row">
                    <div class="article-editor-switch-copy">
                        <span class="article-editor-switch-label" data-i18n="user_form_is_admin">{{ form.isAdmin.vars.label }}</span>
                        <span class="article-editor-switch-hint" data-i18n="user_form_is_admin_hint">Nadaje dostęp do całej sekcji `/admin`.</span>
                    </div>
                    <label class="article-editor-switch">
                        {{ form_widget(form.isAdmin, { attr: { class: 'article-editor-switch-input' } }) }}
                        <span class="article-editor-switch-slider" aria-hidden="true"></span>
                    </label>
                </div>
                {% if is_admin_has_errors %}
                    <div class="article-editor-error-message" role="alert">
                        {% for error in form.isAdmin.vars.errors %}
                            <p>{{ error.message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {% set is_active_has_errors = form.isActive.vars.errors|length > 0 %}
            <div class="field article-editor-field{{ is_active_has_errors ? ' has-error' : '' }}">
                <div class="article-editor-switch-row">
                    <div class="article-editor-switch-copy">
                        <span class="article-editor-switch-label" data-i18n="user_form_is_active">{{ form.isActive.vars.label }}</span>
                        <span class="article-editor-switch-hint" data-i18n="user_form_is_active_hint">Nieaktywne konto nie przejdzie walidacji przy logowaniu.</span>
                    </div>
                    <label class="article-editor-switch">
                        {{ form_widget(form.isActive, { attr: { class: 'article-editor-switch-input' } }) }}
                        <span class="article-editor-switch-slider" aria-hidden="true"></span>
                    </label>
                </div>
                {% if is_active_has_errors %}
                    <div class="article-editor-error-message" role="alert">
                        {% for error in form.isActive.vars.errors %}
                            <p>{{ error.message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        {% set password_has_errors = form.plainPassword.vars.errors|length > 0 %}
        <div class="field article-editor-field{{ password_has_errors ? ' has-error' : '' }}">
            {{ form_label(form.plainPassword) }}
            {{ form_widget(form.plainPassword, {
                attr: form.plainPassword.vars.attr|merge(password_has_errors ? {'aria-invalid': 'true', 'aria-describedby': form.plainPassword.vars.id ~ '-error'} : {})
            }) }}
            <div class="article-editor-field-meta">
                <span class="article-editor-field-hint" data-i18n="user_form_password_hint">Hasło jest opcjonalne. Uzupełnij tylko wtedy, gdy chcesz je zmienić.</span>
            </div>
            {% if password_has_errors %}
                <div id="{{ form.plainPassword.vars.id }}-error" class="article-editor-error-message" role="alert">
                    {% for error in form.plainPassword.vars.errors %}
                        <p>{{ error.message }}</p>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    {{ form_rest(form) }}

    <div class="actions article-editor-actions">
        <button class="button" type="submit" data-i18n="{{ submit_label_key|default('user_form_submit_save') }}">{{ submit_label|default('Zapisz użytkownika') }}</button>
        <a class="button secondary" href="{{ path('admin_user_index') }}" data-i18n="user_form_back_to_list">Wróć do listy</a>
    </div>
{{ form_end(form) }}
