{{ form_start(form, { attr: { class: 'article-editor-form' } }) }}
    {% if form.vars.errors|length > 0 %}
        <div class="form-errors article-editor-errors" role="alert">
            {% for error in form.vars.errors %}
                <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <div class="article-editor-fields">
        <section class="blog-settings-subsection" data-i18n-aria="blog_settings_section_identity_title" aria-label="Tożsamość i SEO">
            <div class="blog-settings-subsection-header">
                <span class="pill">admin://identity-and-seo</span>
                <p class="blog-settings-subsection-lede" data-i18n="blog_settings_section_identity_lede">Ustawienia odpowiedzialne za adres aplikacji, nazwę bloga oraz metadane strony głównej.</p>
            </div>

            {% set app_url_has_errors = form.appUrl.vars.errors|length > 0 %}
            {% set app_url_counter_id = form.appUrl.vars.id ~ '-char-count' %}
            {% set app_url_described_by = app_url_counter_id ~ (app_url_has_errors ? ' ' ~ form.appUrl.vars.id ~ '-error' : '') %}
            <div class="field article-editor-field blog-settings-inline-field blog-settings-inline-field-with-counter{{ app_url_has_errors ? ' has-error' : '' }}">
                <div class="blog-settings-inline-field-copy">
                    <div class="blog-settings-label-row">
                        {{ form_label(form.appUrl) }}
                        <button
                            type="button"
                            class="article-keyword-help-trigger"
                            data-i18n-tooltip="blog_settings_app_url_hint"
                            data-i18n-aria="blog_settings_app_url_hint_aria"
                            data-tooltip="Ten adres jest używany do budowania canonicali, linków do udostępniania i pełnych URL-i obrazków SEO."
                            data-tooltip-wide="true"
                            data-tooltip-wrap="true"
                            aria-label="Pomoc do pola URL aplikacji"
                        >?</button>
                    </div>
                </div>
                <div class="blog-settings-input-stack">
                    <div class="blog-settings-input-row">
                        {{ form_widget(form.appUrl, { attr: {
                            class: 'article-editor-input',
                            placeholder: 'https://twoja-domena.pl',
                            'data-character-count-input': 'true',
                            'aria-describedby': app_url_described_by
                        }|merge(app_url_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                        <div class="article-editor-field-meta">
                            <span id="{{ app_url_counter_id }}" class="article-editor-character-count" data-character-count-target>{{ form.appUrl.vars.value|default('')|length }} / {{ form.appUrl.vars.attr.maxlength }}</span>
                        </div>
                    </div>
                </div>
                {% if app_url_has_errors %}
                    <div id="{{ form.appUrl.vars.id }}-error" class="article-editor-error-message" role="alert">
                        {% for error in form.appUrl.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {% set title_has_errors = form.blogTitle.vars.errors|length > 0 %}
            {% set title_counter_id = form.blogTitle.vars.id ~ '-char-count' %}
            {% set title_described_by = title_counter_id ~ (title_has_errors ? ' ' ~ form.blogTitle.vars.id ~ '-error' : '') %}
            <div class="field article-editor-field blog-settings-inline-field blog-settings-inline-field-with-counter{{ title_has_errors ? ' has-error' : '' }}">
                <div class="blog-settings-inline-field-copy">
                    {{ form_label(form.blogTitle) }}
                </div>
                <div class="blog-settings-input-stack">
                    <div class="blog-settings-input-row">
                        {{ form_widget(form.blogTitle, { attr: {
                            class: 'article-editor-input',
                            placeholder: 'Np. Blog System AI',
                            'data-character-count-input': 'true',
                            'aria-describedby': title_described_by
                        }|merge(title_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                        <div class="article-editor-field-meta">
                            <span id="{{ title_counter_id }}" class="article-editor-character-count" data-character-count-target>{{ form.blogTitle.vars.value|default('')|length }} / {{ form.blogTitle.vars.attr.maxlength }}</span>
                        </div>
                    </div>
                </div>
                {% if title_has_errors %}
                    <div id="{{ form.blogTitle.vars.id }}-error" class="article-editor-error-message" role="alert">
                        {% for error in form.blogTitle.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {% set description_has_errors = form.homepageSeoDescription.vars.errors|length > 0 %}
            {% set description_counter_id = form.homepageSeoDescription.vars.id ~ '-char-count' %}
            {% set description_described_by = description_counter_id ~ (description_has_errors ? ' ' ~ form.homepageSeoDescription.vars.id ~ '-error' : '') %}
            <div class="field article-editor-field blog-settings-inline-field blog-settings-textarea-field{{ description_has_errors ? ' has-error' : '' }}">
                <div class="blog-settings-inline-field-copy">
                    {{ form_label(form.homepageSeoDescription) }}
                </div>
                {{ form_widget(form.homepageSeoDescription, { attr: {
                    class: 'article-editor-input article-editor-textarea',
                    placeholder: 'Krótki opis strony głównej bloga dla Google i innych wyszukiwarek',
                    'data-character-count-input': 'true',
                    'aria-describedby': description_described_by
                }|merge(description_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                <div class="article-editor-field-meta">
                    <span id="{{ description_counter_id }}" class="article-editor-character-count" data-character-count-target>{{ form.homepageSeoDescription.vars.value|default('')|length }} / {{ form.homepageSeoDescription.vars.attr.maxlength }}</span>
                </div>
                {% if description_has_errors %}
                    <div id="{{ form.homepageSeoDescription.vars.id }}-error" class="article-editor-error-message" role="alert">
                        {% for error in form.homepageSeoDescription.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {% set social_image_has_errors = form.homepageSocialImage.vars.errors|length > 0 %}
            {% set social_image_counter_id = form.homepageSocialImage.vars.id ~ '-char-count' %}
            {% set social_image_described_by = social_image_counter_id ~ (social_image_has_errors ? ' ' ~ form.homepageSocialImage.vars.id ~ '-error' : '') %}
            <div class="field article-editor-field blog-settings-inline-field blog-settings-inline-field-with-counter{{ social_image_has_errors ? ' has-error' : '' }}">
                <div class="blog-settings-inline-field-copy">
                    <div class="blog-settings-label-row">
                        {{ form_label(form.homepageSocialImage) }}
                        <button
                            type="button"
                            class="article-keyword-help-trigger"
                            data-i18n-tooltip="blog_settings_homepage_social_image_hint"
                            data-i18n-aria="blog_settings_homepage_social_image_hint_aria"
                            data-tooltip="Podaj pełny URL albo ścieżkę zaczynającą się od /."
                            data-tooltip-wide="true"
                            data-tooltip-wrap="true"
                            aria-label="Pomoc do pola obrazek dla strony głównej"
                        >?</button>
                    </div>
                </div>
                <div class="blog-settings-input-stack">
                    <div class="blog-settings-input-row">
                        {{ form_widget(form.homepageSocialImage, { attr: {
                            class: 'article-editor-input',
                            placeholder: 'https://... lub /assets/img/...',
                            'data-character-count-input': 'true',
                            'aria-describedby': social_image_described_by
                        }|merge(social_image_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                        <div class="article-editor-field-meta">
                            <span id="{{ social_image_counter_id }}" class="article-editor-character-count" data-character-count-target>{{ form.homepageSocialImage.vars.value|default('')|length }} / {{ form.homepageSocialImage.vars.attr.maxlength }}</span>
                        </div>
                    </div>
                </div>
                {% if social_image_has_errors %}
                    <div id="{{ form.homepageSocialImage.vars.id }}-error" class="article-editor-error-message" role="alert">
                        {% for error in form.homepageSocialImage.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {% set keywords_has_errors = form.homepageSeoKeywords.vars.errors|length > 0 %}
            {% set keywords_counter_id = form.homepageSeoKeywords.vars.id ~ '-char-count' %}
            {% set keywords_described_by = keywords_counter_id ~ (keywords_has_errors ? ' ' ~ form.homepageSeoKeywords.vars.id ~ '-error' : '') %}
            <div class="field article-editor-field blog-settings-inline-field blog-settings-textarea-field{{ keywords_has_errors ? ' has-error' : '' }}">
                <div class="blog-settings-inline-field-copy">
                    {{ form_label(form.homepageSeoKeywords) }}
                </div>
                {{ form_widget(form.homepageSeoKeywords, { attr: {
                    class: 'article-editor-input article-editor-textarea',
                    placeholder: 'Np. blog, php, programowanie, architektura aplikacji',
                    'data-character-count-input': 'true',
                    'aria-describedby': keywords_described_by
                }|merge(keywords_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                <div class="article-editor-field-meta">
                    <span id="{{ keywords_counter_id }}" class="article-editor-character-count" data-character-count-target>{{ form.homepageSeoKeywords.vars.value|default('')|length }} / {{ form.homepageSeoKeywords.vars.attr.maxlength }}</span>
                </div>
                {% if keywords_has_errors %}
                    <div id="{{ form.homepageSeoKeywords.vars.id }}-error" class="article-editor-error-message" role="alert">
                        {% for error in form.homepageSeoKeywords.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </section>

        <section class="blog-settings-subsection" data-blog-settings-pagination-section data-i18n-aria="blog_settings_section_pagination_title" aria-label="Globalne ustawienia paginacji">
            <div class="blog-settings-subsection-header">
                <span class="pill">admin://pagination-settings</span>
                <p class="blog-settings-subsection-lede" data-i18n="blog_settings_section_pagination_lede">Skonfiguruj liczbę elementów widocznych na jednej stronie zarówno na stronie głównej bloga, jak i na listach w panelu administracyjnym.</p>
            </div>

            {% set articles_per_page_has_errors = form.articlesPerPage.vars.errors|length > 0 %}
            {% set articles_per_page_error_id = form.articlesPerPage.vars.id ~ '-error' %}
            {% set articles_per_page_described_by = articles_per_page_has_errors ? articles_per_page_error_id : null %}
            <div class="field article-editor-field blog-settings-pagination-field{{ articles_per_page_has_errors ? ' has-error' : '' }}">
                <div class="blog-settings-pagination-field-copy">
                    <div class="blog-settings-label-row">
                        {{ form_label(form.articlesPerPage) }}
                        <button
                            type="button"
                            class="article-keyword-help-trigger"
                            data-i18n-tooltip="blog_settings_articles_per_page_hint"
                            data-i18n-aria="blog_settings_articles_per_page_hint_aria"
                            data-tooltip="Domyślna wartość to 5. Zmiana wpływa na publiczną listę artykułów na stronie głównej."
                            data-tooltip-wide="true"
                            data-tooltip-wrap="true"
                            aria-label="Pomoc do pola ilość artykułów na stronę"
                        >?</button>
                    </div>
                </div>
                {{ form_widget(form.articlesPerPage, { attr: {
                    class: 'article-editor-input blog-settings-number-input',
                    placeholder: '5',
                    'aria-describedby': articles_per_page_described_by
                }|merge(articles_per_page_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                {% if articles_per_page_has_errors %}
                    <div id="{{ articles_per_page_error_id }}" class="article-editor-error-message" role="alert">
                        {% for error in form.articlesPerPage.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {% set admin_listing_items_per_page_has_errors = form.adminListingItemsPerPage.vars.errors|length > 0 %}
            {% set admin_listing_items_per_page_error_id = form.adminListingItemsPerPage.vars.id ~ '-error' %}
            {% set admin_listing_items_per_page_described_by = admin_listing_items_per_page_has_errors ? admin_listing_items_per_page_error_id : null %}
            <div class="field article-editor-field blog-settings-pagination-field{{ admin_listing_items_per_page_has_errors ? ' has-error' : '' }}">
                <div class="blog-settings-pagination-field-copy">
                    <div class="blog-settings-label-row">
                        {{ form_label(form.adminListingItemsPerPage) }}
                        <button
                            type="button"
                            class="article-keyword-help-trigger"
                            data-i18n-tooltip="blog_settings_admin_listing_items_per_page_hint"
                            data-i18n-aria="blog_settings_admin_listing_items_per_page_hint_aria"
                            data-tooltip="Domyślna wartość to 25. Zmiana wpływa na listy w panelu administracyjnym, w tym artykuły i eksporty."
                            data-tooltip-wide="true"
                            data-tooltip-wrap="true"
                            aria-label="Pomoc do pola ilość elementów na stronę w panelu administracyjnym"
                        >?</button>
                    </div>
                </div>
                {{ form_widget(form.adminListingItemsPerPage, { attr: {
                    class: 'article-editor-input blog-settings-number-input',
                    placeholder: '25',
                    'aria-describedby': admin_listing_items_per_page_described_by
                }|merge(admin_listing_items_per_page_has_errors ? {'aria-invalid': 'true'} : {}) }) }}
                {% if admin_listing_items_per_page_has_errors %}
                    <div id="{{ admin_listing_items_per_page_error_id }}" class="article-editor-error-message" role="alert">
                        {% for error in form.adminListingItemsPerPage.vars.errors %}
                            <p data-i18n="{{ error.message }}">{{ i18n_fallback(error.message) }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </section>
    </div>

    <div class="actions article-editor-actions">
        <button type="submit" class="button" data-i18n="blog_settings_submit">Zapisz ustawienia</button>
        <a class="button secondary" href="{{ path('admin_dashboard') }}" data-i18n="blog_settings_back_to_dashboard">Wróć do panelu</a>
    </div>
{{ form_end(form) }}
