<section class="error-main">
    {% set primary_href = primary_href|default(path('blog_index')) %}
    {% set secondary_href = secondary_href|default('') %}
    {% set secondary_label = secondary_label|default('') %}
    <div class="error-shell">
        <div class="card error-card">
            <div class="card-header">
                <div class="window-dots" aria-hidden="true">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                </div>
                <span class="pill">error://{{ status_code }}</span>
            </div>

            <div class="error-body">
                <p class="error-prompt"{% if prompt_i18n_key is defined and prompt_i18n_key is not empty %} data-i18n="{{ prompt_i18n_key }}"{% endif %}>{{ prompt }}</p>
                <p class="error-code">{{ status_code }}</p>
                <p class="error-text"{% if message_i18n_key is defined and message_i18n_key is not empty %} data-i18n="{{ message_i18n_key }}"{% endif %}>{{ message }}</p>
                <div class="error-actions">
                    <a class="button" href="{{ primary_href }}"{% if home_label_i18n_key is defined and home_label_i18n_key is not empty %} data-i18n="{{ home_label_i18n_key }}"{% endif %}>{{ home_label }}</a>
                    {% if secondary_href is not empty and secondary_label is not empty %}
                        <a class="button secondary" href="{{ secondary_href }}"{% if secondary_label_i18n_key is defined and secondary_label_i18n_key is not empty %} data-i18n="{{ secondary_label_i18n_key }}"{% endif %}>{{ secondary_label }}</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>
