{% extends 'base.html.twig' %}

{% set force_non_admin_layout = true %}
{% set show_admin_shortcuts = false %}
{% set page_title_i18n_key = 'error_not_found_page_title' %}

{% block title %}{{ ui_translate('Nie znaleziono strony', 'Page not found') }} | {{ app_name }}{% endblock %}

{% block meta_robots %}noindex,follow{% endblock %}

{% block body %}
    {% include 'error/_status_page.html.twig' with {
        status_code: 404,
        prompt: ui_translate('Nie znaleziono zasobu', 'Resource not found'),
        prompt_i18n_key: 'error_not_found_prompt',
        message: ui_translate('Wygląda na to, że adres jest nieprawidłowy albo artykuł został usunięty, ukryty lub jeszcze nie został opublikowany.', 'The address appears to be invalid, or the article was removed, hidden, or has not been published yet.'),
        message_i18n_key: 'error_not_found_message',
        primary_href: path('blog_index'),
        primary_label: ui_translate('Wróć na stronę główną', 'Back to homepage'),
        primary_label_i18n_key: 'error_back_home',
        secondary_href: path('blog_index') ~ '#articles',
        secondary_label: ui_translate('Przejdź do listy artykułów', 'Browse articles'),
        secondary_label_i18n_key: 'error_browse_articles',
    } only %}
{% endblock %}
