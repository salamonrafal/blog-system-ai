{% extends 'base.html.twig' %}

{% set force_non_admin_layout = true %}
{% set show_admin_shortcuts = false %}

{% block title %}{{ ui_translate('Brak dostępu', 'Access denied') }} | {{ app_name }}{% endblock %}

{% block body %}
    {% include 'error/_status_page.html.twig' with {
        status_code: 403,
        prompt: ui_translate('Sekcja administracyjna', 'Administration section'),
        message: ui_translate('Nie masz uprawnień, aby wejść do tej sekcji. Jeśli potrzebujesz dostępu administratora, skontaktuj się z właścicielem systemu.', 'You do not have permission to enter this section. If you need administrator access, contact the system owner.'),
        primary_href: path('blog_index'),
        primary_label: ui_translate('Wróć na stronę główną', 'Back to homepage'),
        secondary_href: app.user ? path('app_logout') : path('app_login'),
        secondary_label: app.user ? ui_translate('Wyloguj się i zmień konto', 'Log out and switch account') : ui_translate('Przejdź do logowania', 'Go to login'),
    } only %}
{% endblock %}
