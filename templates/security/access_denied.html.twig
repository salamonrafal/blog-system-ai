{% extends 'base.html.twig' %}

{% set force_non_admin_layout = true %}
{% set show_admin_shortcuts = false %}

{% block title %}{{ i18n_fallback('error_access_denied_title') }} | {{ app_name }}{% endblock %}

{% block body %}
    {% include 'error/_status_page.html.twig' with {
        status_code: 403,
        prompt: i18n_fallback('error_access_denied_prompt'),
        message: i18n_fallback('error_access_denied_message'),
        primary_href: path('blog_index'),
        primary_label: i18n_fallback('error_back_home'),
        secondary_href: app.user ? path('app_logout') : path('app_login'),
        secondary_label: app.user ? i18n_fallback('error_access_denied_logout') : i18n_fallback('error_access_denied_login'),
    } only %}
{% endblock %}
