{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} | {{ app_name }}{% endblock %}
{% block canonical %}{{ app_url ~ path('blog_show', {slug: article.slug}) }}{% endblock %}
{% block meta_description %}{{ article.excerpt ?: article.content|striptags|slice(0, 160) ~ (article.content|length > 160 ? '...' : '') }}{% endblock %}
{% block og_description %}{{ block('meta_description') }}{% endblock %}
{% block og_url %}{{ block('canonical') }}{% endblock %}
{% block twitter_description %}{{ block('meta_description') }}{% endblock %}
{% block og_image %}{% if article.resolvedHeadlineImage %}{{ article.resolvedHeadlineImage starts with 'http://' or article.resolvedHeadlineImage starts with 'https://' ? article.resolvedHeadlineImage : app_url ~ article.resolvedHeadlineImage }}{% else %}{{ parent() }}{% endif %}{% endblock %}
{% block twitter_image %}{{ block('og_image') }}{% endblock %}

{% block body %}
    <section class="section">
        <article class="card">
            <div class="card-header">
                <span class="pill">blog://article-body</span>
                <span class="pill">published://{{ article.publishedAt ? article.publishedAt|user_date('stamp') : article.createdAt|user_date('stamp') }}</span>
            </div>

            <div class="article-content-panel">
                {% if article.resolvedHeadlineImage %}
                    <figure class="article-headline-figure">
                        <img
                            src="{{ article.resolvedHeadlineImage }}"
                            alt="{{ article.title }}"
                            class="article-headline-image"
                            loading="eager"
                            decoding="async"
                        >
                        <figcaption class="article-headline-caption">
                            <div class="article-headline-header">
                                <h1 class="article-headline-title">{{ article.title }}</h1>
                                {% if article.category %}
                                    {% include 'blog/_category_badge.html.twig' with {
                                        category: article.category,
                                        route_params: article_category_route_params,
                                        standalone: false,
                                    } only %}
                                {% endif %}
                            </div>
                        </figcaption>
                    </figure>
                {% else %}
                    <div class="dashboard-feed-intro">
                        <div class="article-headline-header article-headline-header-standalone">
                            <h1>{{ article.title }}</h1>
                            {% if article.category %}
                                {% include 'blog/_category_badge.html.twig' with {
                                    category: article.category,
                                    route_params: article_category_route_params,
                                    standalone: true,
                                } only %}
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
                {% if table_of_contents is not empty %}
                    <nav class="article-table-of-contents" aria-labelledby="article-table-of-contents-title">
                        <div class="article-table-of-contents-header">
                            <div id="article-table-of-contents-title" class="article-table-of-contents-eyebrow">
                                <span data-lang="pl">Spis treści</span>
                                <span data-lang="en">Table of contents</span>
                            </div>
                        </div>
                        <ul class="article-table-of-contents-list">
                            {% for item in table_of_contents %}
                                <li class="article-table-of-contents-item level-{{ item.level }}">
                                    <a href="#{{ item.id }}" class="article-table-of-contents-link">{{ item.title }}</a>
                                </li>
                            {% endfor %}
                        </ul>
                    </nav>
                {% endif %}
                <div class="article-body">
                    {{ article.content|article_markup }}
                </div>
                {% if article_keywords is not empty %}
                    <section class="article-keywords-panel">
                        <div class="article-keywords-header">
                            <div class="article-keywords-eyebrow">
                                <span data-lang="pl">Słowa kluczowe</span>
                                <span data-lang="en">Keywords</span>
                            </div>
                        </div>
                        <div class="article-keywords-list">
                            {% for item in article_keywords %}
                                {% set keyword = item.keyword %}
                                <a
                                    class="article-keyword-badge"
                                    href="{{ path('blog_keyword', item.route_params) }}"
                                    {% if keyword.color %}style="--keyword-accent: {{ keyword.color }};"{% endif %}
                                >
                                    <span class="article-keyword-badge-dot" aria-hidden="true"></span>
                                    <span class="article-keyword-badge-label">{{ keyword.name }}</span>
                                </a>
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}
                <div class="actions article-content-actions">
                    <a
                        class="button secondary article-action-button"
                        href="{{ path('blog_index') }}"
                        data-i18n-tooltip="blog_back_to_articles"
                        data-tooltip="Wróć do artykułów"
                        aria-label="Wróć do artykułów"
                    >
                        <span class="article-action-icon is-back" aria-hidden="true"></span>
                    </a>
                    <button
                        class="button secondary article-action-button"
                        type="button"
                        data-action="copy-article-link"
                        data-link="{{ app_url ~ path('blog_show', {slug: article.slug}) }}"
                        data-i18n-tooltip="blog_copy_link"
                        data-tooltip="Kopiuj link"
                        aria-label="Kopiuj link"
                    >
                        <span class="article-action-icon is-copy" aria-hidden="true"></span>
                    </button>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a
                            class="button secondary article-action-button"
                            href="{{ path('admin_article_edit', {id: article.id}) }}"
                            data-i18n-tooltip="blog_edit_in_admin"
                            data-tooltip="Edytuj w panelu admina"
                            aria-label="Edytuj w panelu admina"
                        >
                            <span class="article-action-icon is-edit" aria-hidden="true"></span>
                        </a>
                    {% endif %}
                </div>
                {% set author = article.createdBy %}
                {% if author %}
                    {% set author_name = author.nickname ?: author.fullName ?: author.email %}
                    {% set normalized_author_name = author_name|trim %}
                    {% set author_name_parts = normalized_author_name|replace({'-': ' ', '_': ' ', '@': ' '})|split(' ') %}
                    {% set author_first_initial = normalized_author_name|slice(0, 1)|upper %}
                    {% set author_second_initial = author_name_parts|length > 1 ? author_name_parts[1]|slice(0, 1)|upper : normalized_author_name|slice(1, 1)|upper %}
                    {% set author_initials = (author_first_initial ~ author_second_initial)|trim %}
                    {% set author_badge_color = random(['#ef4444', '#f97316', '#eab308', '#22c55e', '#06b6d4', '#3b82f6', '#ec4899']) %}
                    <aside class="article-author-panel" style="--author-accent: {{ author_badge_color }};">
                        <div class="article-author-avatar">
                            {% if author.avatar %}
                                <img src="{{ author.avatar }}" alt="{{ author_name }}" class="article-author-avatar-image" loading="lazy" decoding="async">
                            {% else %}
                                <div class="article-author-avatar-fallback" aria-hidden="true">{{ author_initials }}</div>
                            {% endif %}
                        </div>
                        <div class="article-author-copy">
                            <div class="article-author-eyebrow">
                                <span data-lang="pl">Autor artykułu</span>
                                <span data-lang="en">Article author</span>
                            </div>
                            <h2 class="article-author-name">{{ author_name }}</h2>
                            <p class="article-author-bio">
                                {% if author.shortBio %}
                                    {{ author.shortBio }}
                                {% else %}
                                    <span data-lang="pl">Autor nie dodał jeszcze krótkiego opisu profilu.</span>
                                    <span data-lang="en">The author has not added a short profile description yet.</span>
                                {% endif %}
                            </p>
                        </div>
                    </aside>
                {% endif %}
                {% if recommended_articles is not empty %}
                    <aside class="article-recommendations-panel">
                        <div class="article-recommendations-eyebrow">
                            <span data-lang="pl">Polecane artykuły</span>
                            <span data-lang="en">Recommended articles</span>
                        </div>
                        <ul class="article-recommendations-list">
                            {% for recommended_article in recommended_articles %}
                                <li>
                                    <a href="{{ path('blog_show', {slug: recommended_article.slug}) }}" class="article-recommendations-link">
                                        {{ recommended_article.title }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    </aside>
                {% endif %}
            </div>
        </article>
    </section>

    {% if app.user %}
        <section class="section">
            <aside class="card article-metadata-card">
                <div class="card-header">
                    <span class="pill" data-i18n="blog_metadata">Metadane</span>
                </div>
                <div class="stats article-metadata-stats">
                    <div class="stat article-metadata-stat">
                        <strong>
                            <span data-lang="pl">
                                {% if article.status.value == 'draft' %}Szkic{% elseif article.status.value == 'review' %}W recenzji{% elseif article.status.value == 'archived' %}Zarchiwizowany{% else %}Opublikowany{% endif %}
                            </span>
                            <span data-lang="en">
                                {% if article.status.value == 'draft' %}Draft{% elseif article.status.value == 'review' %}In review{% elseif article.status.value == 'archived' %}Archived{% else %}Published{% endif %}
                            </span>
                        </strong>
                        <span class="supporting-copy" data-i18n="blog_publication_status">Bieżący status publikacji</span>
                    </div>
                    <div class="stat article-metadata-stat">
                        <strong>{{ article.publishedAt ? article.publishedAt|user_date('date') : article.createdAt|user_date('date') }}</strong>
                        <span class="supporting-copy" data-i18n="blog_public_date">Główna data publiczna</span>
                    </div>
                    <div class="stat article-metadata-stat">
                        <strong>
                            <span data-lang="pl">{{ article.language.value == 'pl' ? 'Polski (PL)' : 'Angielski (EN)' }}</span>
                            <span data-lang="en">{{ article.language.value == 'pl' ? 'Polish (PL)' : 'English (EN)' }}</span>
                        </strong>
                        <span class="supporting-copy" data-i18n="blog_article_language">Język publikacji</span>
                    </div>
                    <div class="stat article-metadata-stat">
                        <strong>{{ article.slug }}</strong>
                        <span class="supporting-copy" data-i18n="blog_reader_slug">Slug widoczny dla czytelnika</span>
                    </div>
                </div>
            </aside>
        </section>
    {% endif %}
{% endblock %}
