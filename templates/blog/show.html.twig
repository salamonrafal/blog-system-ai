{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <article class="card">
            <div class="card-header">
                <span class="pill">blog://article-body</span>
                <span class="pill">published://{{ article.publishedAt ? article.publishedAt|date('Y-m-d_H:i') : article.createdAt|date('Y-m-d_H:i') }}</span>
            </div>

            <div class="dashboard-feed-intro">
                <h1>{{ article.title }}</h1>
            </div>

            <div class="article-content-panel">
                <div class="article-body">
                    {{ article.content|article_markup }}
                </div>
                <div class="actions article-content-actions">
                    <a class="button secondary" href="{{ path('blog_index') }}" data-i18n="blog_back_to_articles">Wróć do artykułów</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a class="button" href="{{ path('admin_article_edit', {id: article.id}) }}" data-i18n="blog_edit_in_admin">Edytuj w panelu admina</a>
                    {% endif %}
                </div>
            </div>
        </article>
    </section>

    {% if app.user %}
        <section class="section">
            <aside class="card article-metadata-card">
                <div class="card-header">
                    <span class="pill" data-i18n="blog_metadata">Metadane</span>
                </div>
                <div class="stats article-metadata-stats">
                    <div class="stat article-metadata-stat">
                        <strong>
                            <span data-lang="pl">
                                {% if article.status.value == 'draft' %}Szkic{% elseif article.status.value == 'review' %}W recenzji{% elseif article.status.value == 'archived' %}Zarchiwizowany{% else %}Opublikowany{% endif %}
                            </span>
                            <span data-lang="en">
                                {% if article.status.value == 'draft' %}Draft{% elseif article.status.value == 'review' %}In review{% elseif article.status.value == 'archived' %}Archived{% else %}Published{% endif %}
                            </span>
                        </strong>
                        <span class="supporting-copy" data-i18n="blog_publication_status">Bieżący status publikacji</span>
                    </div>
                    <div class="stat article-metadata-stat">
                        <strong>{{ article.publishedAt ? article.publishedAt|date('Y-m-d') : article.createdAt|date('Y-m-d') }}</strong>
                        <span class="supporting-copy" data-i18n="blog_public_date">Główna data publiczna</span>
                    </div>
                    <div class="stat article-metadata-stat">
                        <strong>
                            <span data-lang="pl">{{ article.language.value == 'pl' ? 'Polski (PL)' : 'Angielski (EN)' }}</span>
                            <span data-lang="en">{{ article.language.value == 'pl' ? 'Polski (PL)' : 'English (EN)' }}</span>
                        </strong>
                        <span class="supporting-copy" data-i18n="blog_article_language">Język publikacji</span>
                    </div>
                    <div class="stat article-metadata-stat">
                        <strong>{{ article.slug }}</strong>
                        <span class="supporting-copy" data-i18n="blog_reader_slug">Slug widoczny dla czytelnika</span>
                    </div>
                </div>
            </aside>
        </section>
    {% endif %}
{% endblock %}
