{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} | {{ app_name }}{% endblock %}

{% block body %}
    <section class="hero">
        <div class="hero-grid">
            <article class="card">
                <p class="eyebrow meta-pill">{{ article.language.label() }} article</p>
                <h1>{{ article.title }}</h1>
                <p class="lede">
                    {% if article.excerpt %}
                        {{ article.excerpt }}
                    {% else %}
                        Published content page generated from the Twig blog view.
                    {% endif %}
                </p>

                <div class="actions">
                    <a class="button secondary" href="{{ path('blog_index') }}">Back to articles</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a class="button" href="{{ path('admin_article_edit', {id: article.id}) }}">Edit in admin</a>
                    {% endif %}
                </div>
            </article>

            <aside class="card">
                <div class="card-header">
                    <span class="pill">Metadata</span>
                </div>
                <div class="stats">
                    <div class="stat">
                        <strong>{{ article.status.label() }}</strong>
                        <span class="supporting-copy">Current publication status</span>
                    </div>
                    <div class="stat">
                        <strong>{{ article.publishedAt ? article.publishedAt|date('Y-m-d') : article.createdAt|date('Y-m-d') }}</strong>
                        <span class="supporting-copy">Primary public date</span>
                    </div>
                    <div class="stat">
                        <strong>{{ article.slug }}</strong>
                        <span class="supporting-copy">Reader-facing slug</span>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    <section class="section">
        <div class="panel">
            <div class="card-header">
                <span class="pill">Article body</span>
                <span class="meta">{{ article.publishedAt ? article.publishedAt|date('Y-m-d H:i') : article.createdAt|date('Y-m-d H:i') }}</span>
            </div>
            <div class="article-body">
                {{ article.content|nl2br }}
            </div>
        </div>
    </section>
{% endblock %}
