{% extends 'base.html.twig' %}

{% block title %}
    {% if current_keyword %}
        {{ current_keyword.name }} | {{ app_name }}
    {% else %}
        Articles | {{ app_name }}
    {% endif %}
{% endblock %}
{% block meta_description %}{{ blog_settings.homepageSeoDescription }}{% endblock %}
{% block meta_keywords %}{{ blog_settings.homepageSeoKeywords }}{% endblock %}
{% block og_description %}{{ blog_settings.homepageSeoDescription }}{% endblock %}
{% block og_image %}{{ blog_settings.resolvedHomepageSocialImage }}{% endblock %}
{% block twitter_description %}{{ blog_settings.homepageSeoDescription }}{% endblock %}
{% block twitter_image %}{{ blog_settings.resolvedHomepageSocialImage }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <span class="pill">blog://published-feed</span>
            </div>
            <div class="dashboard-feed-intro">
                {% set category_language_code = user_language ?? 'pl' %}
                {% set category_localized_title = current_category ? current_category.title(category_language_code, null) : null %}
                {% set category_localized_description = current_category ? current_category.description(category_language_code, null) : null %}
                {% set category_title_fallback = i18n_fallback('blog_category_fallback_title') %}
                {% set category_description_fallback = i18n_fallback('blog_category_fallback_description') %}
                {% set keyword_title_fallback = i18n_fallback('blog_keyword_fallback_title') %}
                {% set keyword_description_fallback = i18n_fallback('blog_keyword_fallback_description') %}
                {% set category_base_title = current_category ? current_category.name : null %}
                {% set category_base_description = current_category ? current_category.shortDescription : null %}
                {% set category_title = current_category ? (category_localized_title ?: category_base_title ?: category_title_fallback) : null %}
                {% set category_description = current_category ? (category_localized_description ?: category_base_description ?: category_description_fallback) : null %}
                {% set keyword_title = current_keyword ? (keyword_title_fallback ~ ': ' ~ current_keyword.name) : null %}
                {% set keyword_description = current_keyword ? keyword_description_fallback : null %}
                <h1{% if not current_category and not current_keyword %} data-i18n="blog_feed_title"{% elseif current_category and not category_localized_title and not category_base_title %} data-i18n="blog_category_fallback_title"{% endif %}>{{ keyword_title ?: category_title ?: 'Blog o programowaniu, technologii i praktyce tworzenia produktów' }}</h1>
                <p class="lede"{% if not current_category and not current_keyword %} data-i18n="blog_feed_lede"{% elseif current_category and not category_localized_description and not category_base_description %} data-i18n="blog_category_fallback_description"{% endif %}>{{ keyword_description ?: category_description ?: 'Znajdziesz tutaj artykuły o PHP, web developmencie, architekturze aplikacji, jakości kodu i codziennej pracy nad nowoczesnymi produktami cyfrowymi.' }}</p>
                {% if current_keyword %}
                    <div class="article-keywords-list article-keywords-list-featured">
                        <span class="article-keyword-badge is-static"{% if current_keyword.color %} style="--keyword-accent: {{ current_keyword.color }};"{% endif %}>
                            <span class="article-keyword-badge-dot" aria-hidden="true"></span>
                            <span class="article-keyword-badge-label">{{ current_keyword.name }}</span>
                        </span>
                    </div>
                {% endif %}
            </div>

            <nav class="blog-category-section" data-i18n-aria="blog_categories_aria" aria-label="Lista kategorii artykułów">
                <span class="blog-category-title" data-i18n="blog_categories_title">Kategorie artykułów</span>
                {% set category_base_params = current_language ? { lang: current_language.value } : {} %}
                <div class="blog-category-links">
                    <a class="blog-category-link{{ current_category ? '' : ' is-current' }}" href="{{ path('blog_index', category_base_params) }}"{% if not current_category %} aria-current="page"{% endif %}>
                        <span class="blog-category-link-name" data-i18n="blog_categories_all">Wszystkie</span>
                    </a>
                    {% for item in categories %}
                        {% set category = item.category %}
                        {% set is_current = current_category_slug and current_category_slug == item.slug %}
                        {% set category_nav_title = category.title(category_language_code, null) ?: category.name %}
                        <a class="blog-category-link{{ is_current ? ' is-current' : '' }}" href="{{ path('blog_category', category_base_params|merge({ slug: item.slug })) }}"{% if is_current %} aria-current="page"{% endif %}>
                            <span class="blog-category-link-name">{{ category_nav_title }}</span>
                        </a>
                    {% endfor %}
                </div>
            </nav>

            {% if articles is not empty %}
                <div class="quick-links feed-panel-list">
                    {% for article in articles %}
                        <article class="big-link no-hover article-subpanel">
                            <a class="article-subpanel-headline-link{{ article.resolvedHeadlineImage ? '' : ' article-subpanel-headline-link-fallback' }}" href="{{ path('blog_show', {slug: article.slug}) }}" aria-label="{{ article.title }}">
                                {% if article.resolvedHeadlineImage %}
                                    <img src="{{ article.resolvedHeadlineImage }}" alt="{{ article.title }}" class="article-subpanel-headline-image" loading="lazy" decoding="async">
                                {% else %}
                                    <span class="article-subpanel-headline-image article-subpanel-headline-image-fallback" aria-hidden="true"></span>
                                {% endif %}
                                <span class="article-subpanel-headline-caption">
                                    <span class="article-subpanel-headline-title">{{ article.title }}</span>
                                </span>
                            </a>
                            <div class="article-subpanel-header">
                                <div class="meta article-subpanel-meta">
                                    <span class="article-subpanel-meta-icon" aria-hidden="true"></span>
                                    {{ article.publishedAt ? article.publishedAt|user_date : article.createdAt|user_date }}
                                    {% if article.createdBy %}
                                        <span class="article-subpanel-meta-separator" aria-hidden="true">•</span>
                                        <span class="article-subpanel-meta-icon article-subpanel-meta-author-icon" aria-hidden="true"></span>
                                        {{ article.createdBy.nickname ?: article.createdBy.fullName ?: article.createdBy.email }}
                                    {% endif %}
                                </div>
                            </div>
                            <div class="big-link-copy">
                                <span>{{ article.excerpt ?: article.content|slice(0, 230) ~ (article.content|length > 230 ? '...' : '') }}</span>
                            </div>
                            <div class="article-subpanel-actions">
                                <a class="btn article-subpanel-button" href="{{ path('blog_show', {slug: article.slug}) }}" data-i18n="blog_read_article">Czytaj artykuł</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>

                {% if total_pages > 1 %}
                    <nav class="blog-pagination" aria-label="Paginacja artykułów">
                        {% set base_params = pagination_route_params %}
                        {% if current_page > 1 %}
                            <a class="btn blog-pagination-link blog-pagination-link-icon" href="{{ path(pagination_route, base_params|merge({ page: current_page - 1 })) }}" aria-label="Poprzednia strona">
                                <span aria-hidden="true">&lsaquo;</span>
                            </a>
                        {% else %}
                            <span class="btn blog-pagination-link blog-pagination-link-icon is-disabled" aria-disabled="true" aria-label="Poprzednia strona">
                                <span aria-hidden="true">&lsaquo;</span>
                            </span>
                        {% endif %}

                        <div class="blog-pagination-pages">
                            {% for item in pagination_items %}
                                {% if item == '...' %}
                                    <span class="blog-pagination-ellipsis" aria-hidden="true">...</span>
                                {% elseif item == current_page %}
                                    <span class="btn blog-pagination-link is-current" aria-current="page">{{ item }}</span>
                                {% else %}
                                    <a class="btn blog-pagination-link" href="{{ path(pagination_route, base_params|merge({ page: item })) }}">{{ item }}</a>
                                {% endif %}
                            {% endfor %}
                        </div>

                        {% if current_page < total_pages %}
                            <a class="btn blog-pagination-link blog-pagination-link-icon" href="{{ path(pagination_route, base_params|merge({ page: current_page + 1 })) }}" aria-label="Następna strona">
                                <span aria-hidden="true">&rsaquo;</span>
                            </a>
                        {% else %}
                            <span class="btn blog-pagination-link blog-pagination-link-icon is-disabled" aria-disabled="true" aria-label="Następna strona">
                                <span aria-hidden="true">&rsaquo;</span>
                            </span>
                        {% endif %}
                    </nav>
                {% endif %}

                {% if top_keywords is not empty %}
                    <section class="article-keywords-panel article-keywords-panel-top-list">
                        <div class="article-keywords-header">
                            <span class="blog-category-title article-keywords-top-title" data-i18n="blog_top_keywords_title">TOP 5 słów kluczowych</span>
                        </div>
                        <div class="article-keywords-top-listing">
                            {% for item in top_keywords %}
                                <a
                                    class="article-keyword-badge article-keyword-badge-top"
                                    href="{{ path('blog_keyword', item.route_params) }}"
                                    {% if item.keyword.color %}style="--keyword-accent: {{ item.keyword.color }};"{% endif %}
                                >
                                    <span class="article-keyword-badge-dot" aria-hidden="true"></span>
                                    <span class="article-keyword-badge-label">{{ item.keyword.name }}</span>
                                    <span class="article-keyword-count">{{ item.article_count }}</span>
                                </a>
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}
            {% else %}
                <div class="blog-empty-state">
                    <p class="meta blog-empty-state-message" role="status" data-i18n="blog_no_articles">Brak opublikowanych artykułów.</p>
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="actions blog-empty-state-actions">
                            <a class="btn primary" href="{{ path('admin_article_new') }}" data-i18n="blog_create_first_article">Utwórz pierwszy artykuł</a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}
