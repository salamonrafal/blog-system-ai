{% extends 'base.html.twig' %}

{% block title %}Articles | {{ app_name }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="card">
            <div class="card-header">
                <span class="pill">blog://published-feed</span>
            </div>

            {% if articles is not empty %}
                <div class="quick-links feed-panel-list">
                    {% for article in articles %}
                        <article class="big-link no-hover article-subpanel">
                            <div class="article-subpanel-header">
                                <h2 class="article-subpanel-title">{{ article.title }}</h2>
                                <div class="meta article-subpanel-meta">
                                    {{ article.publishedAt ? article.publishedAt|date('Y-m-d H:i') : article.createdAt|date('Y-m-d H:i') }}
                                    | {{ article.language.label() }}
                                    | {{ article.status.label() }}
                                </div>
                            </div>
                            <div class="big-link-copy">
                                <span>{{ article.excerpt ?: article.content|slice(0, 180) ~ (article.content|length > 180 ? '...' : '') }}</span>
                            </div>
                            <div class="article-subpanel-actions">
                                <a class="btn article-subpanel-button" href="{{ path('blog_show', {slug: article.slug}) }}">Read article</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <p class="meta">No published articles yet.</p>
                {% if is_granted('ROLE_ADMIN') %}
                    <div class="actions" style="margin-top: 1rem;">
                        <a class="btn primary" href="{{ path('admin_article_new') }}">Create the first article</a>
                    </div>
                {% endif %}
            {% endif %}
        </div>
    </section>

    <section class="hero">
        <div class="grid-2">
            <div class="card">
                <div class="card-header">
                    <span class="pill">Reader view</span>
                </div>
                <h1>Articles ready for readers</h1>
                <p class="lede">Published content is now grouped into one main feed panel placed directly below the topbar, while this section keeps the supporting context and controls.</p>

                <div class="stats">
                    <div class="stat">
                        <strong>{{ articles|length }}</strong>
                        <span class="supporting-copy">Published articles in the current selection</span>
                    </div>
                    <div class="stat">
                        <strong>{{ language_options|length }}</strong>
                        <span class="supporting-copy">Configured language variants</span>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="pill">Filters</span>
                </div>
                <div class="filters" style="margin-top: 1rem;">
                    <a class="{{ current_language is null ? '' : 'secondary' }}" href="{{ path('blog_index') }}">All languages</a>
                    {% for language in language_options %}
                        <a class="{{ current_language == language ? '' : 'secondary' }}" href="{{ path('blog_index', {lang: language.value}) }}">{{ language.label() }}</a>
                    {% endfor %}
                </div>
                {% if is_granted('ROLE_ADMIN') %}
                    <div class="actions" style="margin-top: 1rem;">
                        <a class="btn" href="{{ path('admin_article_new') }}">Create article</a>
                        <a class="btn" href="{{ path('admin_article_index') }}">Manage articles</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
