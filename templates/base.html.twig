<!doctype html>
<html lang="pl" data-theme="dark">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{% block meta_description %}{{ blog_settings.homepageSeoDescription }}{% endblock %}">
    <meta name="keywords" content="{% block meta_keywords %}{{ blog_settings.homepageSeoKeywords }}{% endblock %}">
    <meta name="robots" content="index,follow,max-image-preview:large">
    <meta name="author" content="Rafał Salamon">
    <meta name="theme-color" content="#0b0f12">
    <script>
        (function() {
            try {
                var storedTheme = window.localStorage.getItem('theme');
                var theme = storedTheme === 'light' ? 'light' : 'dark';
                if (storedTheme !== theme) {
                    window.localStorage.setItem('theme', theme);
                }
                document.documentElement.setAttribute('data-theme', theme);
            } catch (error) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <link rel="canonical" href="{% block canonical %}{{ app_url ~ path('blog_index') }}{% endblock %}">
    <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
    {% if app_env == 'prod' %}
        <link rel="stylesheet" href="/assets/build/styles.min.css">
    {% else %}
        <link rel="stylesheet" href="/assets/css/styles.css">
    {% endif %}

    <meta property="og:locale" content="pl_PL">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ app_name }}">
    <meta property="og:title" content="{% block og_title %}{% block title %}{{ app_name }}{% endblock %}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:url" content="{% block og_url %}{{ app_url ~ path('blog_index') }}{% endblock %}">
    <meta property="og:image" content="{% block og_image %}{{ blog_settings.resolvedHomepageSocialImage }}{% endblock %}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% block twitter_title %}{{ block('og_title') }}{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}{{ block('og_description') }}{% endblock %}">
    <meta name="twitter:image" content="{% block twitter_image %}{{ block('og_image') }}{% endblock %}">

    <title>{{ block('title') }}</title>
</head>

{% set route_name = app.request.attributes.get('_route')|default('') %}
{% set is_admin_route = route_name starts with 'admin_' %}
{% set is_dashboard_shortcut_active = route_name == 'admin_dashboard' %}
{% set is_new_article_shortcut_active = route_name == 'admin_article_new' %}
{% set is_content_shortcut_active = (
    route_name starts with 'admin_article_'
    and route_name != 'admin_article_new'
    and not (route_name starts with 'admin_article_import_')
    and not (route_name starts with 'admin_article_export_')
) or (
    route_name starts with 'admin_top_menu_'
    and not (route_name starts with 'admin_top_menu_import_')
) %}
{% set is_media_shortcut_active = route_name starts with 'admin_media_' %}
{% set is_users_shortcut_active = route_name starts with 'admin_user_' %}
{% set is_import_export_shortcut_active = route_name == 'admin_queue_status' or route_name starts with 'admin_article_import_' or route_name starts with 'admin_category_import_' or route_name starts with 'admin_top_menu_import_' or route_name starts with 'admin_article_export_' %}
{% set is_blog_settings_shortcut_active = route_name == 'admin_blog_settings' %}

<body
    data-page-title="{% block page_title %}{{ block('title') }}{% endblock %}"
    {% if is_admin_route %}
        data-admin-page="true"
    {% endif %}
    {% if is_granted('ROLE_ADMIN') %}
        data-user-notifications-endpoint="{{ path('admin_user_notification_pending') }}"
        data-user-notifications-csrf="{{ csrf_token('consume_user_notifications') }}"
    {% endif %}
>
{% if is_admin_route %}
    <script>
        (function(){
            var body = document.body;

            if(!(body instanceof HTMLBodyElement)){
                return;
            }

            var released = false;
            var release = function(){
                if(released){
                    return;
                }

                released = true;
                body.classList.remove('admin-preload-pending');
            };

            body.classList.add('admin-preload-pending');
            window.addEventListener('load', function(){
                window.requestAnimationFrame(release);
            }, { once: true });
            window.setTimeout(release, 5000);
        })();
    </script>
    <div class="admin-preloader" data-admin-preloader>
        <div class="admin-preloader-backdrop" aria-hidden="true"></div>
        <div class="admin-preloader-status" role="status" aria-live="polite" aria-atomic="true">
            <div class="admin-preloader-scene" aria-hidden="true">
                <div class="admin-preloader-ekg">
                    <span class="admin-preloader-ekg-line"></span>
                    <span class="admin-preloader-ekg-trace">
                        <svg viewBox="0 0 180 72" preserveAspectRatio="none" aria-hidden="true">
                            <path d="M0 40 H44 L54 40 L62 24 L70 56 L80 34 L92 40 H180"></path>
                        </svg>
                    </span>
                    <span class="admin-preloader-heart">
                        <svg viewBox="0 0 32 32" aria-hidden="true">
                            <path d="M16 28 5 17.5C2.6 15.2 2.4 11.2 4.5 8.9c2.2-2.4 6-2.5 8.4-.4L16 11.2l3.1-2.7c2.4-2.1 6.2-2 8.4.4 2.1 2.3 1.9 6.3-.5 8.6Z"></path>
                        </svg>
                    </span>
                </div>
            </div>
            <span class="sr-only" data-i18n="admin_preloader_status">Ładowanie panelu administracyjnego</span>
        </div>
    </div>
    <noscript>
        <style>
            .admin-preloader{ display: none !important; }
        </style>
    </noscript>
{% endif %}

<header class="topbar">
    <div class="topbar-inner">
        <a class="brand" href="{{ path('blog_index') }}" data-i18n-aria="site_home_aria" aria-label="Strona główna">
            <img src="/assets/img/logo.svg" alt="RS logo">
            <div class="title">
                <strong>Rafał Salamon</strong>
                <span data-i18n="home_title">Senior PHP Developer
Fullstack Developer</span>
            </div>
        </a>

        <nav class="nav" data-i18n-aria="site_primary_navigation_aria" aria-label="Nawigacja główna">
            {% include '_top_menu_items.html.twig' with { items: top_menu_items } %}
        </nav>

        <div class="actions">
            <button class="hamburger" data-action="toggle-menu" aria-label="Menu">☰</button>
            <div class="chip preferences-chip">
                <div class="prefs-actions">
                    <button type="button" data-action="toggle-lang" data-i18n-tooltip="prefs_lang_hint" data-tooltip="Przełącza język strony">PL</button>
                    <button type="button" data-action="toggle-theme" data-i18n-tooltip="prefs_theme_hint" data-tooltip="Przełącza motyw jasny/ciemny">🌙</button>
                    <span class="prefs-color-wrap" data-i18n-tooltip="prefs_color_hint" data-tooltip="Zmienia kolor akcentu interfejsu"><input class="color-input" type="color" data-action="accent-color" value="#39ff14" data-i18n-aria="prefs_accent_color_aria" aria-label="Kolor akcentu"></span>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="mobile-drawer" role="dialog" data-i18n-aria="site_mobile_menu_aria" aria-label="Menu mobilne">
    {% include '_mobile_top_menu_items.html.twig' with { items: top_menu_items } %}
    <div class="mobile-controls">
        <div class="chip mobile-preferences" title="User preferences / Preferencje użytkownika">
            <span data-i18n="chip_prefs">Preferencje</span>
            <div class="prefs-actions">
                <button type="button" data-action="toggle-lang">PL</button>
                <button type="button" data-action="toggle-theme">🌙</button>
                <input class="color-input" type="color" data-action="accent-color" value="#39ff14" data-i18n-aria="prefs_accent_color_aria" aria-label="Kolor akcentu">
            </div>
        </div>
    </div>
</div>

<div class="flash-stack" aria-live="polite" aria-atomic="true">
    {% for message in app.flashes('success') %}
        <div class="flash" role="status">
            <span class="flash-message">{{ message }}</span>
            <button type="button" class="flash-close" data-action="dismiss-flash" data-i18n-aria="admin_close_alert" aria-label="Zamknij alert">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash error" role="alert">
            <span class="flash-message">{{ message }}</span>
            <button type="button" class="flash-close" data-action="dismiss-flash" data-i18n-aria="admin_close_alert" aria-label="Zamknij alert">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {% endfor %}
</div>

<main class="container">

    {% block body %}{% endblock %}
</main>

{% set is_login_route = app.request.attributes.get('_route') == 'app_login' %}
{% if app.user or not is_login_route %}
