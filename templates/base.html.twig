                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            {% if app.user %}
                <div class="admin-shortcuts-section admin-shortcuts-section-pinned">
                    <a class="admin-shortcuts-link primary{{ is_new_article_shortcut_active ? ' is-active' : '' }}" href="{{ path('admin_article_new') }}"{% if is_new_article_shortcut_active %} aria-current="page"{% endif %}>
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M16 6v20"></path>
                                <path d="M6 16h20"></path>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_new_article">Utwórz nowy artykuł</span>
                    </a>
                </div>
                <div class="admin-shortcuts-scroll">
                    <div class="admin-shortcuts-section">
                    <a class="admin-shortcuts-link{{ is_dashboard_shortcut_active ? ' is-active' : '' }}" href="{{ path('admin_dashboard') }}"{% if is_dashboard_shortcut_active %} aria-current="page"{% endif %}>
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <rect x="5" y="5" width="9" height="9" rx="2"></rect>
                                <rect x="18" y="5" width="9" height="6" rx="2"></rect>
                                <rect x="18" y="14" width="9" height="13" rx="2"></rect>
                                <rect x="5" y="18" width="9" height="9" rx="2"></rect>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_dashboard">Panel główny</span>
                    </a>
                    <div class="admin-shortcuts-submenu" data-admin-shortcuts-submenu data-route-active="{{ is_content_shortcut_active ? 'true' : 'false' }}">
                        <button type="button" class="admin-shortcuts-link admin-shortcuts-button admin-shortcuts-submenu-trigger{{ is_content_shortcut_active ? ' is-active' : '' }}" data-action="toggle-admin-submenu" aria-haspopup="true" aria-expanded="false" aria-controls="admin-shortcuts-content-management-panel">
                            <span class="admin-shortcuts-link-icon" aria-hidden="true">
                                <svg viewBox="0 0 32 32">
                                    <path d="M8 9h16"></path>
                                    <path d="M8 16h16"></path>
                                    <path d="M8 23h10"></path>
                                    <circle cx="23" cy="23" r="3"></circle>
                                </svg>
                            </span>
                            <span data-i18n="admin_shortcut_content_management_title">Zarządzanie treścią</span>
                            <span class="admin-shortcuts-submenu-caret" aria-hidden="true">
                                <svg viewBox="0 0 32 32">
                                    <path d="M10 13l6 6 6-6"></path>
                                </svg>
                            </span>
                        </button>
                        <div class="admin-shortcuts-submenu-panel" id="admin-shortcuts-content-management-panel" data-i18n-aria="admin_shortcut_content_management_title" aria-label="Zarządzanie treścią">
                            <a class="admin-shortcuts-link admin-shortcuts-sublink{{ route_name == 'admin_article_index' ? ' is-active' : '' }}" href="{{ path('admin_article_index') }}"{% if route_name == 'admin_article_index' %} aria-current="page"{% endif %}>
                                <span class="admin-shortcuts-link-icon" aria-hidden="true">
                                    <svg viewBox="0 0 32 32">
                                        <path d="M10 9h14"></path>
                                        <path d="M10 16h14"></path>
                                        <path d="M10 23h14"></path>
                                        <circle cx="7" cy="9" r="1.5"></circle>
                                        <circle cx="7" cy="16" r="1.5"></circle>
                                        <circle cx="7" cy="23" r="1.5"></circle>
                                    </svg>
                                </span>
                                <span data-i18n="admin_shortcut_articles">Lista artykułów</span>
                            </a>
                            <a class="admin-shortcuts-link admin-shortcuts-sublink{{ route_name starts with 'admin_article_category_' ? ' is-active' : '' }}" href="{{ path('admin_article_category_index') }}"{% if route_name == 'admin_article_category_index' %} aria-current="page"{% endif %}>
                                <span class="admin-shortcuts-link-icon" aria-hidden="true">
                                    <svg viewBox="0 0 32 32">
                                        <path d="M8 10h10l6 6-8 8-8-8Z"></path>
                                        <circle cx="13" cy="13" r="1.5"></circle>
                                    </svg>
                                </span>
                                <span data-i18n="admin_shortcut_categories">Kategorie artykułów</span>
                            </a>
                            <a class="admin-shortcuts-link admin-shortcuts-sublink{{ route_name starts with 'admin_article_keyword_' ? ' is-active' : '' }}" href="{{ path('admin_article_keyword_index') }}"{% if route_name == 'admin_article_keyword_index' %} aria-current="page"{% endif %}>
