<!doctype html>
<html lang="pl" data-theme="dark">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{% block meta_description %}{{ blog_settings.homepageSeoDescription }}{% endblock %}">
    <meta name="keywords" content="{% block meta_keywords %}{{ blog_settings.homepageSeoKeywords }}{% endblock %}">
    <meta name="robots" content="index,follow,max-image-preview:large">
    <meta name="author" content="Rafał Salamon">
    <meta name="theme-color" content="#0b0f12">

    <link rel="canonical" href="{% block canonical %}https://www.salamonrafal.pl/{% endblock %}">
    <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/assets/css/styles.css">

    <meta property="og:locale" content="pl_PL">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ app_name }}">
    <meta property="og:title" content="{% block og_title %}{% block title %}{{ app_name }}{% endblock %}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:url" content="{% block og_url %}https://www.salamonrafal.pl/{% endblock %}">
    <meta property="og:image" content="{% block og_image %}{{ blog_settings.homepageSocialImage }}{% endblock %}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% block twitter_title %}{{ block('og_title') }}{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}{{ block('og_description') }}{% endblock %}">
    <meta name="twitter:image" content="{% block twitter_image %}{{ block('og_image') }}{% endblock %}">

    <title>{{ block('title') }}</title>
</head>

<body data-page-title="{% block page_title %}{{ block('title') }}{% endblock %}">
<header class="topbar">
    <div class="topbar-inner">
        <a class="brand" href="https://www.salamonrafal.pl/" aria-label="Home">
            <img src="/assets/img/logo.svg" alt="RS logo">
            <div class="title">
                <strong>Rafał Salamon</strong>
                <span data-i18n="home_title">Senior PHP Developer
Fullstack Developer</span>
            </div>
        </a>

        <nav class="nav" aria-label="Primary">
            <a href="https://www.salamonrafal.pl/" data-i18n="nav_home">Start</a>
            <a href="https://www.salamonrafal.pl/about.html" data-i18n="nav_about">O mnie</a>
            <a href="https://www.salamonrafal.pl/projects.html" data-i18n="nav_projects">Moje projekty</a>
            <a href="https://www.salamonrafal.pl/tools.html" data-i18n="nav_tools">Moje narzędzia</a>
            <a href="{{ path('blog_index') }}" data-i18n="nav_blog">Blog</a>
            <a href="https://www.salamonrafal.pl/contact.html" data-i18n="nav_contact">Kontakt</a>
        </nav>

        <div class="actions">
            <button class="hamburger" data-action="toggle-menu" aria-label="Menu">☰</button>
            <div class="chip preferences-chip">
                <div class="prefs-actions">
                    <button type="button" data-action="toggle-lang" data-i18n-tooltip="prefs_lang_hint" data-tooltip="Przełącza język strony">PL</button>
                    <button type="button" data-action="toggle-theme" data-i18n-tooltip="prefs_theme_hint" data-tooltip="Przełącza motyw jasny/ciemny">🌙</button>
                    <span class="prefs-color-wrap" data-i18n-tooltip="prefs_color_hint" data-tooltip="Zmienia kolor akcentu interfejsu"><input class="color-input" type="color" data-action="accent-color" value="#39ff14" aria-label="Accent color"></span>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="mobile-drawer" role="dialog" aria-label="Mobile menu">
    <a href="https://www.salamonrafal.pl/" data-i18n="nav_home">Start</a>
    <a href="https://www.salamonrafal.pl/about.html" data-i18n="nav_about">O mnie</a>
    <a href="https://www.salamonrafal.pl/projects.html" data-i18n="nav_projects">Moje projekty</a>
    <a href="https://www.salamonrafal.pl/tools.html" data-i18n="nav_tools">Moje narzędzia</a>
    <a href="{{ path('blog_index') }}" data-i18n="nav_blog">Blog</a>
    <a href="https://www.salamonrafal.pl/contact.html" data-i18n="nav_contact">Kontakt</a>
    <div class="mobile-controls">
        <div class="chip mobile-preferences" title="User preferences / Preferencje użytkownika">
            <span data-i18n="chip_prefs">Preferencje</span>
            <div class="prefs-actions">
                <button type="button" data-action="toggle-lang">PL</button>
                <button type="button" data-action="toggle-theme">🌙</button>
                <input class="color-input" type="color" data-action="accent-color" value="#39ff14" aria-label="Accent color">
            </div>
        </div>
    </div>
</div>

<div class="flash-stack" aria-live="polite" aria-atomic="true">
    {% for message in app.flashes('success') %}
        <div class="flash" role="status">
            <span class="flash-message">{{ message }}</span>
            <button type="button" class="flash-close" data-action="dismiss-flash" data-i18n-aria="admin_close_alert" aria-label="Zamknij alert">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash error" role="alert">
            <span class="flash-message">{{ message }}</span>
            <button type="button" class="flash-close" data-action="dismiss-flash" data-i18n-aria="admin_close_alert" aria-label="Zamknij alert">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {% endfor %}
</div>

<main class="container">

    {% block body %}{% endblock %}
</main>

{% set is_login_route = app.request.attributes.get('_route') == 'app_login' %}
{% if app.user or not is_login_route %}
    <details class="admin-shortcuts"{% if not app.user %} hidden{% endif %}>
        <summary class="admin-shortcuts-toggle" aria-label="Admin shortcuts">
            <span class="admin-shortcuts-gear" aria-hidden="true">
                <svg viewBox="0 0 32 32">
                    <path d="M13.2 4h5.6l.7 3.2c.9.3 1.8.7 2.6 1.3l3.1-1.1 2.8 4.8-2.5 2.2c.1.5.1 1 .1 1.6s0 1.1-.1 1.6l2.5 2.2-2.8 4.8-3.1-1.1c-.8.6-1.7 1-2.6 1.3l-.7 3.2h-5.6l-.7-3.2c-.9-.3-1.8-.7-2.6-1.3l-3.1 1.1-2.8-4.8 2.5-2.2a9.2 9.2 0 0 1 0-3.2l-2.5-2.2 2.8-4.8 3.1 1.1c.8-.6 1.7-1 2.6-1.3Z"></path>
                    <circle cx="16" cy="16" r="4.2"></circle>
                </svg>
            </span>
        </summary>
        <nav class="admin-shortcuts-menu" aria-label="Admin shortcuts" data-admin-shortcuts data-authenticated="{{ app.user ? 'true' : 'false' }}">
            {% if app.user %}
                <div class="admin-shortcuts-section">
                    <a class="admin-shortcuts-link primary" href="{{ path('admin_article_new') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M16 6v20"></path>
                                <path d="M6 16h20"></path>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_new_article">Utwórz nowy artykuł</span>
                    </a>
                    <a class="admin-shortcuts-link" href="{{ path('admin_dashboard') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <rect x="5" y="5" width="9" height="9" rx="2"></rect>
                                <rect x="18" y="5" width="9" height="6" rx="2"></rect>
                                <rect x="18" y="14" width="9" height="13" rx="2"></rect>
                                <rect x="5" y="18" width="9" height="9" rx="2"></rect>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_dashboard">Panel główny</span>
                    </a>
                    <a class="admin-shortcuts-link" href="{{ path('admin_article_index') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M10 9h14"></path>
                                <path d="M10 16h14"></path>
                                <path d="M10 23h14"></path>
                                <circle cx="7" cy="9" r="1.5"></circle>
                                <circle cx="7" cy="16" r="1.5"></circle>
                                <circle cx="7" cy="23" r="1.5"></circle>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_articles">Lista artykułów</span>
                    </a>
                    <a class="admin-shortcuts-link" href="{{ path('app_logout') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M20 25h-9a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h9"></path>
                                <path d="M17 16h10"></path>
                                <path d="M23 11l5 5-5 5"></path>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_logout">Wyloguj</span>
                    </a>
                </div>
                <section class="admin-shortcuts-section admin-shortcuts-settings" aria-label="Quick settings">
                    <p class="admin-shortcuts-section-title" data-i18n="admin_shortcut_settings_title">Szybkie ustawienia</p>
                    <button type="button" class="admin-shortcuts-link admin-shortcuts-button" data-action="toggle-device-login" aria-pressed="false">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <rect x="8" y="5" width="16" height="22" rx="3"></rect>
                                <path d="M12 9h8"></path>
                                <circle cx="16" cy="23" r="1.4"></circle>
                            </svg>
                        </span>
                        <span data-device-remember-label data-i18n="admin_shortcut_remember_device">Zapamiętaj urządzenie</span>
                    </button>
                    <a class="admin-shortcuts-link" href="{{ path('admin_blog_settings') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M7 11h18"></path>
                                <path d="M7 21h18"></path>
                                <path d="M11 7v8"></path>
                                <path d="M21 17v8"></path>
                                <circle cx="11" cy="17" r="2"></circle>
                                <circle cx="21" cy="15" r="2"></circle>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_blog_settings">Ustawienia bloga</span>
                    </a>
                    <a class="admin-shortcuts-link" href="{{ path('admin_queue_status') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <rect x="6" y="7" width="20" height="5" rx="1.5"></rect>
                                <rect x="6" y="14" width="20" height="5" rx="1.5"></rect>
                                <rect x="6" y="21" width="20" height="5" rx="1.5"></rect>
                                <path d="M11 9.5h.01"></path>
                                <path d="M11 16.5h.01"></path>
                                <path d="M11 23.5h.01"></path>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_queue_status">Stan kolejek</span>
                    </a>
                    <a class="admin-shortcuts-link" href="{{ path('admin_article_import_index') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M16 7v13"></path>
                                <path d="M11 12l5-5 5 5"></path>
                                <path d="M7 25h18"></path>
                                <rect x="6" y="24" width="20" height="2" rx="1"></rect>
                            </svg>
                        </span>
                        <span>Importy</span>
                    </a>
                    <a class="admin-shortcuts-link" href="{{ path('admin_article_export_index') }}">
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M16 6v13"></path>
                                <path d="M11 15l5 5 5-5"></path>
                                <path d="M7 24h18"></path>
                                <rect x="6" y="24" width="20" height="2" rx="1"></rect>
                            </svg>
                        </span>
                        <span data-i18n="admin_shortcut_exports">Eksporty</span>
                    </a>
                </section>
            {% else %}
                <a class="admin-shortcuts-link primary" href="{{ path('app_login') }}">
                    <span class="admin-shortcuts-link-icon" aria-hidden="true">
                        <svg viewBox="0 0 32 32">
                            <path d="M20 25h-9a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h9"></path>
                            <path d="M17 16h10"></path>
                            <path d="M23 11l5 5-5 5"></path>
                        </svg>
                    </span>
                    <span data-i18n="admin_shortcut_login_device">Zaloguj się</span>
                </a>
            {% endif %}
        </nav>
    </details>
{% endif %}

<footer class="footer">
    <div class="footer-inner">
        <div class="footer-text">
            <span>&copy;</span>
            <a class="footer-home-link" href="https://www.salamonrafal.pl/">Rafał Salamon</a>
            <span>•</span>
            <span data-i18n="footer">Tworzę rzeczy, które są czytelne, solidne i praktyczne.</span>
            <span class="footer-break" aria-hidden="true"></span>
            <a class="footer-sub-link" href="https://www.salamonrafal.pl/evaluation.html">Zobacz ewolucję strony</a>
        </div>
        <div class="footer-icons" aria-label="Social links">
            <a class="footer-icon-link" href="https://github.com/salamonrafal" target="_blank" rel="noreferrer" aria-label="GitHub" title="GitHub"><span class="footer-icon" aria-hidden="true"><svg viewBox="0 0 32 32"><path d="M16 5C9.9 5 5 9.9 5 16c0 4.9 3.2 9 7.6 10.4.6.1.8-.3.8-.6v-2.2c-3.1.7-3.8-1.3-3.8-1.3-.5-1.3-1.2-1.7-1.2-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 .1 1.7.9 2 1.4.9.2 1.8.2 2.6-.1.1-.7.4-1.3.8-1.7-2.5-.3-5.1-1.2-5.1-5.4 0-1.2.4-2.2 1.1-3-.1-.3-.5-1.4.1-2.9 0 0 .9-.3 3 .1.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.1-.4 3-.1 3-.1.6 1.5.2 2.6.1 2.9.7.8 1.1 1.8 1.1 3 0 4.2-2.6 5.1-5.1 5.4.5.5.9 1.3.9 2.5v3.7c0 .3.2.7.8.6A11 11 0 0 0 27 16c0-6.1-4.9-11-11-11Z" stroke-width="1.7" stroke-linejoin="round"></path></svg></span></a>
            <a class="footer-icon-link" href="https://www.linkedin.com/in/rafalsalamon/" target="_blank" rel="noreferrer" aria-label="LinkedIn" title="LinkedIn"><span class="footer-icon" aria-hidden="true"><svg viewBox="0 0 32 32"><rect x="5" y="11" width="5" height="16" stroke-width="2"></rect><circle cx="7.5" cy="6.5" r="2.5" stroke-width="2"></circle><path d="M15 11v16M15 17c0-3.3 2.2-6 5.6-6 3.1 0 5.4 2.1 5.4 6.6V27h-5v-8.2c0-1.8-.7-3-2.4-3-1.9 0-3 1.4-3 3.4V27h-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></a>
            <a class="footer-icon-link" href="https://buymeacoffee.com/salamonrafal" target="_blank" rel="noreferrer" aria-label="Buy Me a Coffee" title="Buy Me a Coffee"><span class="footer-icon" aria-hidden="true"><svg viewBox="0 0 32 32"><path d="M8 13h14v6a7 7 0 0 1-7 7 7 7 0 0 1-7-7Z" stroke-width="2" stroke-linejoin="round"></path><path d="M22 15h1.5a3.5 3.5 0 0 1 0 7H22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12 9c0 1.7-1.3 2.4-1.3 3.8M17 9c0 1.7-1.3 2.4-1.3 3.8" stroke-width="2" stroke-linecap="round"></path></svg></span></a>
            <a class="footer-icon-link" href="mailto:rafal.salamon@salamonrafal.pl" aria-label="E-mail" title="E-mail"><span class="footer-icon" aria-hidden="true"><svg viewBox="0 0 32 32"><path d="M5 9h22v14H5z" stroke-width="2"></path><path d="M6 10l10 8 10-8M6 23l7-6M26 23l-7-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg></span></a>
        </div>
    </div>
</footer>

<script src="/assets/js/app.js"></script>
</body>
</html>
