                                    <path d="M17 25c.7-2.8 3.1-5 6-5 2.2 0 4.2 1.2 5 3"></path>
                                </svg>
                            </span>
                            <span data-i18n="admin_shortcut_users_title">Użytkownicy</span>
                            <span class="admin-shortcuts-submenu-caret" aria-hidden="true">
                                <svg viewBox="0 0 32 32">
                                    <path d="M10 13l6 6 6-6"></path>
                                </svg>
                            </span>
                        </button>
                        <div class="admin-shortcuts-submenu-panel" id="admin-shortcuts-users-panel" data-i18n-aria="admin_shortcut_users_title" aria-label="Użytkownicy">
                            <a class="admin-shortcuts-link admin-shortcuts-sublink{{ route_name == 'admin_user_new' ? ' is-active' : '' }}" href="{{ path('admin_user_new') }}"{% if route_name == 'admin_user_new' %} aria-current="page"{% endif %}>
                                <span class="admin-shortcuts-link-icon" aria-hidden="true">
                                    <svg viewBox="0 0 32 32">
                                        <circle cx="13" cy="11" r="4"></circle>
                                        <path d="M6 25c0-4 3.1-7 7-7"></path>
                                        <path d="M23 10v8"></path>
                                        <path d="M19 14h8"></path>
                                    </svg>
                                </span>
                                <span data-i18n="admin_shortcut_user_new">Dodaj użytkownika</span>
                            </a>
                            <a class="admin-shortcuts-link admin-shortcuts-sublink{{ route_name starts with 'admin_user_' and route_name != 'admin_user_new' ? ' is-active' : '' }}" href="{{ path('admin_user_index') }}"{% if route_name == 'admin_user_index' %} aria-current="page"{% endif %}>
                                <span class="admin-shortcuts-link-icon" aria-hidden="true">
                                    <svg viewBox="0 0 32 32">
                                        <circle cx="12" cy="11" r="4"></circle>
                                        <path d="M5 25c0-4 3.1-7 7-7"></path>
                                        <circle cx="22" cy="13" r="3"></circle>
                                        <path d="M17 25c.7-2.8 3.1-5 6-5 2.2 0 4.2 1.2 5 3"></path>
                                    </svg>
                                </span>
                                <span data-i18n="admin_shortcut_user_index">Zarządzanie użytkownikami</span>
                            </a>
                        </div>
                    </div>
