                    </div>
                    <div class="admin-shortcuts-submenu" data-admin-shortcuts-submenu data-route-active="{{ is_media_shortcut_active ? 'true' : 'false' }}">
                        <button type="button" class="admin-shortcuts-link admin-shortcuts-button admin-shortcuts-submenu-trigger{{ is_media_shortcut_active ? ' is-active' : '' }}" data-action="toggle-admin-submenu" aria-haspopup="true" aria-expanded="false" aria-controls="admin-shortcuts-media-panel">
                            <span class="admin-shortcuts-link-icon" aria-hidden="true">
                                <svg viewBox="0 0 32 32">
                                    <rect x="5" y="7" width="22" height="18" rx="3"></rect>
