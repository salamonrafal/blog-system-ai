                                        <circle cx="22" cy="16" r="3"></circle>
                                    </svg>
                                </span>
                                <span data-i18n="admin_shortcut_keywords">Słowa kluczowe</span>
                            </a>
                            <a class="admin-shortcuts-link admin-shortcuts-sublink{{ route_name starts with 'admin_top_menu_' and not (route_name starts with 'admin_top_menu_import_') ? ' is-active' : '' }}" href="{{ path('admin_top_menu_index') }}"{% if route_name == 'admin_top_menu_index' %} aria-current="page"{% endif %}>
