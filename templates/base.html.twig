                <svg viewBox="0 0 32 32">
                    <path d="M13.2 4h5.6l.7 3.2c.9.3 1.8.7 2.6 1.3l3.1-1.1 2.8 4.8-2.5 2.2c.1.5.1 1 .1 1.6s0 1.1-.1 1.6l2.5 2.2-2.8 4.8-3.1-1.1c-.8.6-1.7 1-2.6 1.3l-.7 3.2h-5.6l-.7-3.2c-.9-.3-1.8-.7-2.6-1.3l-3.1 1.1-2.8-4.8 2.5-2.2a9.2 9.2 0 0 1 0-3.2l-2.5-2.2 2.8-4.8 3.1 1.1c.8-.6 1.7-1 2.6-1.3Z"></path>
                    <circle cx="16" cy="16" r="4.2"></circle>
                </svg>
            </span>
        </summary>
        <nav class="admin-shortcuts-menu" data-i18n-aria="admin_shortcut_menu_label" aria-label="Skróty administratora" data-admin-shortcuts data-authenticated="{{ app.user ? 'true' : 'false' }}">
            <div class="admin-shortcuts-desktop-bar">
                <span class="admin-shortcuts-desktop-title" data-i18n="admin_shortcut_menu_label">Skróty administratora</span>
                <div class="admin-shortcuts-desktop-actions">
                    <button
                        type="button"
                        class="admin-shortcuts-desktop-collapse"
                        data-action="toggle-admin-shortcuts-collapse"
                        data-i18n-aria="admin_shortcut_collapse"
                        aria-label="Zwiń panel skrótów"
                        aria-pressed="false"
                    >
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <path d="M20 8l-8 8 8 8"></path>
                            </svg>
                        </span>
                    </button>
                    <button
                        type="button"
                        class="admin-shortcuts-desktop-dock"
                        data-action="toggle-admin-shortcuts-dock"
                        data-i18n-aria="admin_shortcut_dock"
                        aria-label="Dokuj panel skrótów"
                        aria-pressed="false"
                    >
                        <span class="admin-shortcuts-link-icon" aria-hidden="true">
                            <svg viewBox="0 0 32 32">
                                <rect x="6" y="7" width="20" height="18" rx="3"></rect>
                                <path d="M12 11v10"></path>
                                <path d="M15 16h8"></path>
                            </svg>
                        </span>
                    </button>
                </div>
            </div>
            <div class="admin-shortcuts-mobile-bar">
                <span class="admin-shortcuts-mobile-title" data-i18n="admin_shortcut_menu_label">Skróty administratora</span>
