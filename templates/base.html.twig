                                    <svg viewBox="0 0 32 32">
                                        <path d="M7 10h18"></path>
                                        <path d="M7 16h12"></path>
                                        <path d="M7 22h16"></path>
                                        <circle cx="24" cy="16" r="2"></circle>
                                    </svg>
                                </span>
                                <span data-i18n="admin_shortcut_top_menu">Top menu</span>
                            </a>
