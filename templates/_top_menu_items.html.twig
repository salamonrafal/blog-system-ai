{% for item in items %}
    <div class="nav-item{{ item.has_children ? ' has-children' : '' }}">
        {% if item.url %}
            <a
                class="nav-link"
                href="{{ item.url }}"
                data-menu-label-pl="{{ item.label_pl }}"
                data-menu-label-en="{{ item.label_en }}"
                {% if item.open_in_new_window|default(false) %} target="_blank" rel="noreferrer noopener"{% endif %}
            >{{ item.label }}</a>
        {% elseif item.has_children %}
            <button
                type="button"
                class="nav-link"
                data-menu-label-pl="{{ item.label_pl }}"
                data-menu-label-en="{{ item.label_en }}"
                aria-haspopup="true"
            >{{ item.label }}</button>
        {% else %}
            <span
                class="nav-link"
                data-menu-label-pl="{{ item.label_pl }}"
                data-menu-label-en="{{ item.label_en }}"
            >{{ item.label }}</span>
        {% endif %}
        {% if item.has_children %}
            <div class="nav-submenu">
                {% include '_top_menu_items.html.twig' with { items: item.children } %}
            </div>
        {% endif %}
    </div>
{% endfor %}
